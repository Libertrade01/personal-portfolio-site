---
interface Props {
  status: 'Built' | 'Prototype' | 'In Progress' | 'Concept';
}

const { status } = Astro.props;

const styles: Record<Props['status'], string> = {
  Built: 'border-emerald-500/25 bg-emerald-500/10 text-emerald-400/90 backdrop-blur-sm',
  Prototype: 'border-blue-500/25 bg-blue-500/10 text-blue-400/90 backdrop-blur-sm',
  'In Progress': 'border-amber-accent/30 bg-amber-accent/10 text-amber-bright backdrop-blur-sm',
  Concept: 'border-white/15 bg-white/5 text-muted backdrop-blur-sm',
};
---

<span
  class:list={[
    'inline-flex rounded-full border px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-wider',
    styles[status],
  ]}
>
  {status}
</span>
