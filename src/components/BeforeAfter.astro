---
interface Props {
  before: string;
  after: string;
}

const { before, after } = Astro.props;
---

<div class="my-8 grid gap-4 md:grid-cols-2">
  <div class="card-surface border-red-500/20 p-5">
    <p class="text-xs uppercase tracking-wider text-red-400/80">Before</p>
    <p class="mt-2 text-sm text-muted">{before}</p>
  </div>
  <div class="card-surface border-emerald-500/20 p-5">
    <p class="text-xs uppercase tracking-wider text-emerald-400/80">After</p>
    <p class="mt-2 text-sm text-off-white">{after}</p>
  </div>
</div>
