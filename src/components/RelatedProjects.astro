---
import type { ProjectEntry } from '../utils/content';

interface Props {
  projects: ProjectEntry[];
  currentSlug: string;
}

const { projects, currentSlug } = Astro.props;
const related = projects.filter((p) => p.slug !== currentSlug).slice(0, 2);
---

{
  related.length > 0 && (
    <section class="related-systems" aria-labelledby="related-systems-title">
      <header class="related-systems__header">
        <p>Continue exploring</p>
        <h2 id="related-systems-title">Related systems</h2>
      </header>
      <div class="related-systems__grid">
        {related.map((project, index) => (
          <article class="related-system">
            <a href={`/projects/${project.slug}`} aria-label={`Read the ${project.data.title} case study`}>
              <div class="related-system__meta">
                <span>System {String(index + 1).padStart(2, '0')}</span>
                <span>{project.data.status}</span>
              </div>
              <div class="related-system__copy">
                <p>{project.data.category}</p>
                <h3>{project.data.title}</h3>
                <span>{project.data.description}</span>
              </div>
              <div class="related-system__foot">
                <span>{project.data.stack.slice(0, 3).join(' · ')}</span>
                <strong>View case study ↗</strong>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
  )
}

<style>
  .related-systems {
    width: var(--ml-shell);
    margin: clamp(5rem, 10vw, 10rem) auto 0;
    padding-top: clamp(2rem, 4vw, 3.5rem);
    border-top: 1px solid var(--ml-line);
  }

  .related-systems__header p,
  .related-system__meta,
  .related-system__foot {
    font-family: var(--font-mono, ui-monospace, monospace);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .related-systems__header p {
    margin: 0;
    color: var(--ml-clay);
    font-size: 0.65rem;
  }

  .related-systems__header h2 {
    margin: 0.75rem 0 0;
    color: var(--ml-ink);
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4vw, 3.6rem);
    font-weight: 400;
    letter-spacing: -0.05em;
  }

  .related-systems__grid {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }

  .related-system {
    background: color-mix(in srgb, var(--ml-paper-raised) 82%, transparent);
    border: 1px solid var(--ml-line);
    transition:
      border-color 220ms ease,
      box-shadow 220ms ease,
      transform 220ms ease;
  }

  .related-system:hover {
    transform: translateY(-3px);
    border-color: var(--ml-line-strong);
    box-shadow: 0 18px 46px rgba(48, 43, 35, 0.08);
  }

  .related-system a {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    color: inherit;
    padding: clamp(1.25rem, 3vw, 2rem);
    text-decoration: none;
  }

  .related-system__meta,
  .related-system__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--ml-muted);
    font-size: 0.6rem;
  }

  .related-system__copy {
    margin-block: clamp(2.5rem, 5vw, 4.5rem);
  }

  .related-system__copy p {
    margin: 0 0 0.6rem;
    color: var(--ml-clay);
    font-size: 0.7rem;
  }

  .related-system__copy h3 {
    margin: 0;
    color: var(--ml-ink);
    font-family: var(--font-sans);
    font-size: clamp(1.6rem, 3vw, 2.6rem);
    font-weight: 400;
    letter-spacing: -0.045em;
  }

  .related-system__copy > span {
    display: block;
    margin-top: 1rem;
    color: var(--ml-muted);
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 1.65;
  }

  .related-system__foot {
    margin-top: auto;
  }

  .related-system__foot strong {
    color: var(--ml-ink-soft);
    font-weight: 500;
    white-space: nowrap;
  }

  @media (min-width: 760px) {
    .related-systems__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
