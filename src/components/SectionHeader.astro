---
interface Props {
  title: string;
  subtitle?: string;
  subtitleClass?: string;
  id?: string;
  label?: string;
  compact?: boolean;
  /** Larger compact title typography — homepage #help section only */
  large?: boolean;
}

const { title, subtitle, subtitleClass, id, label = 'Section', compact = false, large = false } =
  Astro.props;
---

<div id={id} class:list={[compact ? 'mb-8 md:mb-10' : 'mb-14']}>
  <div class="section-label-row">
    <span class="section-label section-label--large">{label}</span>
    <div class="section-label-rule"></div>
  </div>
  <h2
    class:list={[
      'mt-5 font-sans font-semibold tracking-tight text-off-white',
      compact
        ? large
          ? 'text-[2.75rem] leading-tight md:text-[3rem] lg:text-[3.125rem]'
          : 'text-3xl md:text-[2.35rem] md:leading-tight'
        : 'text-3xl font-medium md:text-4xl md:leading-tight',
    ]}
  >
    {title}
  </h2>
  {subtitle && (
    <p
      class:list={[
        'mt-4 max-w-2xl leading-relaxed text-muted',
        compact
          ? large
            ? 'text-lg md:text-xl'
            : 'text-base md:text-lg'
          : 'font-mono text-sm md:text-base',
        subtitleClass,
      ]}
    >
      {subtitle}
    </p>
  )}
</div>
