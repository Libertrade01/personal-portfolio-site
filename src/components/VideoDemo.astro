---
interface Props {
  src: string;
  poster?: string;
  title?: string;
}

const { src, poster, title = 'Project demo' } = Astro.props;
---

<div class="my-8 overflow-hidden rounded-2xl border border-border bg-black shadow-2xl glow-amber">
  <video
    controls
    muted
    playsinline
    preload="metadata"
    poster={poster}
    aria-label={title}
    class="w-full"
  >
    <source src={src} type="video/mp4" />
    Your browser does not support the video tag.
  </video>
</div>
