---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import type { ProjectEntry } from '../utils/content';

interface Props {
  projects: ProjectEntry[];
}

const { projects } = Astro.props;

const preferredFeaturedProject = projects.find(
  (project) =>
    project.slug === 'libertrade-journal-analytics' ||
    project.data.title.toLowerCase().includes('trading review operating system')
);
const featuredProject = preferredFeaturedProject ?? projects[0];
const supportingProjects = featuredProject
  ? projects.filter((project) => project.id !== featuredProject.id)
  : [];

function getCoverDetails(project: ProjectEntry) {
  const { coverImage, coverFit, coverPosition } = project.data;
  const coverRetina = coverImage?.replace(/\.(png|jpe?g|webp)$/i, '@2x.$1');
  const hasRetinaCover =
    Boolean(coverImage && coverRetina) &&
    existsSync(join(process.cwd(), 'public', coverRetina!.replace(/^\//, '')));
  const isPhotoCover = Boolean(coverImage?.match(/\.(png|jpe?g|webp)$/i));
  const fit = coverFit ?? (isPhotoCover ? 'contain' : 'cover');
  const position = coverPosition ?? (fit === 'contain' ? 'top' : 'center');

  return { coverImage, coverRetina, hasRetinaCover, fit, position };
}

const featuredCover = featuredProject ? getCoverDetails(featuredProject) : undefined;
---

<section id="portfolio" class="section-padding-home section-flow home-help-section home-portfolio-featured">
  <div class="container-main">
    <div class="section-label-row home-portfolio-featured__section-label">
      <span class="section-label section-label--large">Portfolio</span>
      <div class="section-label-rule"></div>
    </div>

    <div class="home-portfolio-featured__frame">
      <div class="home-portfolio-featured__intro">
        <h2>Systems I've built</h2>
        <p>Products and workflows that turn messy inputs into structured, reusable output.</p>
      </div>

      {
        featuredProject && featuredCover && (
          <div class="home-portfolio-featured__layout">
            <article class="home-portfolio-featured__anchor">
              <a href={`/projects/${featuredProject.slug}`} class="home-portfolio-featured__anchor-link">
                <div class="home-portfolio-featured__anchor-media">
                  {featuredCover.coverImage ? (
                    <img
                      src={featuredCover.coverImage}
                      {...(featuredCover.hasRetinaCover
                        ? {
                            srcset: `${featuredCover.coverImage} 1x, ${featuredCover.coverRetina} 2x`,
                            sizes: '(min-width: 960px) 54vw, 100vw',
                          }
                        : {})}
                      alt={`${featuredProject.data.title} preview`}
                      class:list={[
                        'home-portfolio-featured__anchor-image',
                        'home-portfolio-featured__image--cover',
                      ]}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="home-portfolio-featured__fallback">
                      {featuredProject.data.title.charAt(0)}
                    </div>
                  )}
                </div>

                <div class="home-portfolio-featured__anchor-body">
                  <span class="home-portfolio-featured__label">Featured case study</span>
                  <span class="home-portfolio-featured__category">
                    {featuredProject.data.category} / {featuredProject.data.status}
                  </span>
                  <h3>{featuredProject.data.title}</h3>
                  <p>{featuredProject.data.description}</p>

                  {featuredProject.data.outcomes.length > 0 && (
                    <ul class="home-portfolio-featured__outcomes" role="list">
                      {featuredProject.data.outcomes.slice(0, 3).map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  )}

                  <span class="home-portfolio-featured__cta">
                    Read case study <span aria-hidden="true">&rarr;</span>
                  </span>
                </div>
              </a>
            </article>

            {supportingProjects.length > 0 && (
              <div class="home-portfolio-featured__supporting">
                {supportingProjects.map((project, index) => {
                  const { coverImage, coverRetina, hasRetinaCover } = getCoverDetails(project);
                  const { title, description, category, status } = project.data;
                  const projectNumber = String(index + 2).padStart(2, '0');

                  return (
                    <article class="home-portfolio-featured__support">
                      <a href={`/projects/${project.slug}`} class="home-portfolio-featured__support-link">
                        <div class="home-portfolio-featured__support-thumb">
                          {coverImage ? (
                            <img
                              src={coverImage}
                              {...(hasRetinaCover
                                ? {
                                    srcset: `${coverImage} 1x, ${coverRetina} 2x`,
                                    sizes: '(min-width: 960px) 5rem, 22vw',
                                  }
                                : {})}
                              alt=""
                              loading="lazy"
                              decoding="async"
                            />
                          ) : (
                            <span>{title.charAt(0)}</span>
                          )}
                        </div>
                        <div class="home-portfolio-featured__support-copy">
                          <span class="home-portfolio-featured__support-meta">
                            {projectNumber} / {category} / {status}
                          </span>
                          <h3>{title}</h3>
                          <p>{description}</p>
                        </div>
                        <span class="home-portfolio-featured__support-arrow" aria-hidden="true">
                          &rarr;
                        </span>
                      </a>
                    </article>
                  );
                })}
              </div>
            )}
          </div>
        )
      }

      <div class="home-portfolio-featured__actionbar" aria-label="View all projects">
        <a href="/projects" class="home-portfolio-featured__cta hero-cta-link">
          All projects
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .home-portfolio-featured {
    color: #111827;
  }

  .home-portfolio-featured__frame {
    --home-portfolio-frame-padding: clamp(1.25rem, 3vw, 2rem);
    background: #faf9f5;
    border: 1px solid #d8d4ca;
    border-radius: 1.5rem;
    box-shadow:
      0 16px 46px rgba(31, 52, 74, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.78);
    overflow: hidden;
    padding: var(--home-portfolio-frame-padding);
  }

  .home-portfolio-featured__section-label {
    margin-bottom: clamp(1.75rem, 4vw, 2.5rem);
  }

  .home-portfolio-featured__intro {
    border-bottom: 1px solid #d8d4ca;
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
  }

  .home-portfolio-featured__label {
    color: #1f344a;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    line-height: 1.45;
    margin: 0;
    text-transform: uppercase;
  }

  .home-portfolio-featured__intro h2 {
    color: #111827;
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin: 0;
  }

  .home-portfolio-featured__intro p {
    color: #4b5563;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0.65rem 0 0;
    max-width: 38rem;
  }

  .home-portfolio-featured__layout {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: minmax(0, 1fr);
  }

  .home-portfolio-featured__anchor {
    background: linear-gradient(180deg, #f6f2eb 0%, #f3eee5 100%);
    border: 1px solid #d7d0c3;
    border-radius: 1.15rem;
  }

  .home-portfolio-featured__anchor-link {
    color: inherit;
    display: grid;
    gap: clamp(1rem, 2vw, 1.35rem);
    grid-template-columns: minmax(0, 1fr);
    height: 100%;
    padding: clamp(0.75rem, 1.6vw, 0.95rem);
    text-decoration: none;
  }

  .home-portfolio-featured__anchor-media {
    background: #fffaf2;
    border-radius: 0.95rem;
    height: clamp(15rem, 58vw, 22rem);
    overflow: hidden;
  }

  .home-portfolio-featured__anchor-media img,
  .home-portfolio-featured__support-thumb img {
    display: block;
    height: 100%;
    width: 100%;
  }

  .home-portfolio-featured__anchor-image {
    border-radius: inherit;
    object-fit: cover;
    object-position: left center;
  }

  .home-portfolio-featured__image--contain {
    object-fit: contain;
    padding: 1rem;
  }

  .home-portfolio-featured__image--cover {
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .home-portfolio-featured__image--top {
    object-position: top;
  }

  .home-portfolio-featured__anchor-link:hover .home-portfolio-featured__image--cover {
    transform: scale(1.03);
  }

  .home-portfolio-featured__fallback {
    align-items: center;
    background: linear-gradient(135deg, #f6f2eb 0%, #1f344a 100%);
    color: rgba(247, 246, 241, 0.35);
    display: flex;
    font-family: var(--font-serif, Georgia, serif);
    font-size: 4rem;
    height: 100%;
    justify-content: center;
  }

  .home-portfolio-featured__anchor-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0.45rem clamp(0.35rem, 1.4vw, 0.8rem) 0.55rem;
  }

  .home-portfolio-featured__category {
    color: #4b5563;
    display: block;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    margin-top: 0.45rem;
    text-transform: uppercase;
  }

  .home-portfolio-featured__anchor-body h3 {
    color: #111827;
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(1.35rem, 2.5vw, 1.85rem);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0.55rem 0 0;
  }

  .home-portfolio-featured__anchor-body p,
  .home-portfolio-featured__support-copy p {
    color: #4b5563;
    font-size: 0.92rem;
    line-height: 1.6;
    margin: 0.65rem 0 0;
  }

  .home-portfolio-featured__outcomes {
    border-top: 1px solid rgba(31, 52, 74, 0.12);
    display: grid;
    gap: 0.45rem;
    list-style: none;
    margin: 1rem 0 0;
    padding: 1rem 0 0;
  }

  .home-portfolio-featured__outcomes li {
    color: #4b5563;
    font-size: 0.88rem;
    line-height: 1.5;
    padding-left: 1rem;
    position: relative;
  }

  .home-portfolio-featured__outcomes li::before {
    color: #1f344a;
    content: '-';
    left: 0;
    position: absolute;
  }

  .home-portfolio-featured__cta {
    color: #1f344a;
    display: inline-flex;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    gap: 0.35rem;
    letter-spacing: 0.1em;
    margin-top: 1rem;
    text-transform: uppercase;
  }

  .home-portfolio-featured__actionbar {
    align-items: center;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.26) 0%, rgba(240, 235, 227, 0.58) 100%),
      rgba(255, 250, 242, 0.32);
    border-top: 1px solid rgba(31, 52, 74, 0.12);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.68),
      0 -1px 0 rgba(255, 255, 255, 0.42);
    display: flex;
    justify-content: center;
    margin:
      clamp(1.25rem, 3vw, 1.75rem) calc(var(--home-portfolio-frame-padding) * -1)
      calc(var(--home-portfolio-frame-padding) * -1);
    padding: clamp(0.85rem, 2vw, 1.05rem) var(--home-portfolio-frame-padding);
  }

  .home-portfolio-featured__actionbar .home-portfolio-featured__cta.hero-cta-link {
    color: rgba(31, 52, 74, 0.78);
    font-size: clamp(0.8rem, 1.5vw, 0.92rem);
    justify-content: center;
    letter-spacing: 0.16em;
    line-height: 1.2;
    margin-top: 0;
    text-decoration: none;
    transition:
      color 180ms ease,
      gap 0.3s ease;
  }

  .home-portfolio-featured__actionbar .home-portfolio-featured__cta.hero-cta-link:hover {
    color: #1f344a;
  }

  .home-portfolio-featured__actionbar .home-portfolio-featured__cta.hero-cta-link span[aria-hidden='true'] {
    color: #1f344a;
  }

  .home-portfolio-featured__supporting {
    display: grid;
    gap: 0.75rem;
  }

  .home-portfolio-featured__support {
    background: #fffaf2;
    border: 1px solid #d7d0c3;
    border-radius: 0.95rem;
  }

  .home-portfolio-featured__support-link {
    align-items: center;
    color: inherit;
    display: grid;
    gap: 0.85rem;
    grid-template-columns: 4.5rem minmax(0, 1fr) auto;
    padding: 0.85rem;
    text-decoration: none;
  }

  .home-portfolio-featured__support-thumb {
    aspect-ratio: 1;
    background: #f6f2eb;
    border: 1px solid #d8d4ca;
    border-radius: 0.65rem;
    overflow: hidden;
  }

  .home-portfolio-featured__support-thumb img {
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center;
    padding: 0;
    width: 100%;
  }

  .home-portfolio-featured__support-thumb span {
    align-items: center;
    color: #1f344a;
    display: flex;
    font-family: var(--font-serif, Georgia, serif);
    font-size: 1.5rem;
    height: 100%;
    justify-content: center;
    opacity: 0.45;
  }

  .home-portfolio-featured__support-meta {
    color: #1f344a;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .home-portfolio-featured__support-copy h3 {
    color: #111827;
    font-family: var(--font-serif, Georgia, serif);
    font-size: 1.1rem;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0.35rem 0 0;
  }

  .home-portfolio-featured__support-copy p {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    margin-top: 0.35rem;
    overflow: hidden;
  }

  .home-portfolio-featured__support-arrow {
    color: #1f344a;
    font-size: 1.1rem;
  }

  @media (min-width: 960px) {
    .home-portfolio-featured__layout {
      grid-template-columns: minmax(0, 1.28fr) minmax(17rem, 0.82fr);
    }

    .home-portfolio-featured__anchor-link {
      grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
    }

    .home-portfolio-featured__anchor-media {
      height: 100%;
      min-height: clamp(22.5rem, 32vw, 26.25rem);
    }
  }

  @media (max-width: 520px) {
    .home-portfolio-featured__frame {
      border-radius: 1rem;
    }

    .home-portfolio-featured__support-link {
      grid-template-columns: 3.75rem minmax(0, 1fr);
    }

    .home-portfolio-featured__support-arrow {
      display: none;
    }
  }
</style>
