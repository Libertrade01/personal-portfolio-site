---

import { hero } from '../config/site';

import HeroCtaBar from './HeroCtaBar.astro';

import HeroTerminalBlock from './HeroTerminalBlock.astro';

const { titleLines, intro } = hero;

---

<section
  class="hero-section home-hero-section relative flex min-h-[calc(100vh-4.25rem)] flex-col justify-center overflow-hidden pb-8 md:pb-10"
>
  <div class="container-hero relative z-10 w-full">
    <div class="hero-content home-hero-frame">
      <div
        class="grid items-start gap-8 lg:grid-cols-2 lg:gap-10 xl:grid-cols-[1.02fr_0.98fr] xl:gap-14"
      >
        <div class="flex flex-col">
          <p class="animate-fade-up section-label hero-eyebrow">{hero.role}</p>

          <h1
            class="animate-fade-up-delay-1 mt-5 font-sans text-[2.5rem] font-bold leading-[1.05] tracking-tight text-off-white sm:text-5xl md:mt-7 md:text-[3.25rem] lg:text-[4.5rem] lg:leading-[1.03] xl:text-[4.75rem]"
          >
            {titleLines.map((line, index) => (
              <>
                {index > 0 && <br />}
                {line}
              </>
            ))}
          </h1>

          <p
            class="animate-fade-up-delay-2 mt-5 max-w-2xl text-lg leading-relaxed text-muted md:mt-7 md:text-xl lg:text-[1.35rem] lg:leading-relaxed"
          >
            {intro}
          </p>
        </div>

        <div class="animate-fade-up-delay-2 w-full lg:pl-2 xl:pl-6">
          <div class="hero-terminal-wrap w-full">
            <HeroTerminalBlock />
          </div>
        </div>
      </div>

      <div class="hero-cta-rail animate-fade-up-delay-3">
        <HeroCtaBar />
      </div>
    </div>
  </div>
</section>
