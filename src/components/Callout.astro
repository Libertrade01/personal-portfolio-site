---
interface Props {
  type?: 'info' | 'tip' | 'warning';
}

const { type = 'info' } = Astro.props;

const styles = {
  info: 'border-amber-accent/30 bg-amber-accent/5',
  tip: 'border-emerald-500/30 bg-emerald-500/5',
  warning: 'border-red-500/30 bg-red-500/5',
};
---

<aside class:list={['my-6 rounded-xl border p-4 text-sm', styles[type]]}>
  <slot />
</aside>
