---
import StatusBadge from './StatusBadge.astro';
import TechStack from './TechStack.astro';
import type { ProjectEntry } from '../utils/content';

interface Props {
  project: ProjectEntry;
  index?: number;
}

const { project, index = 0 } = Astro.props;
const { title, description, status, category, type, stack, coverImage } = project.data;
const num = String(index + 1).padStart(2, '0');
---

<article class="card-surface group flex flex-col overflow-hidden">
  <a href={`/projects/${project.slug}`} class="flex flex-1 flex-col">
    <div class="relative aspect-[16/10] overflow-hidden bg-charcoal">
      {
        coverImage ? (
          <>
            <img
              src={coverImage}
              alt={`${title} preview`}
              class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-charcoal-card via-charcoal-card/20 to-transparent opacity-90"></div>
          </>
        ) : (
          <div class="flex h-full items-center justify-center bg-gradient-to-br from-charcoal-elevated to-charcoal">
            <span class="font-serif text-6xl text-amber-accent/10">{title.charAt(0)}</span>
          </div>
        )
      }
      <span class="absolute left-4 top-4 font-mono text-[10px] text-amber-accent/60">{num}</span>
      <div class="absolute right-4 top-4">
        <StatusBadge status={status} />
      </div>
    </div>

    <div class="relative flex flex-1 flex-col p-6 md:p-7">
      <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-muted">
        {category} · {type}
      </p>
      <h3 class="mt-3 font-serif text-2xl text-off-white transition-colors group-hover:text-amber-bright">
        {title}
      </h3>
      <p class="mt-3 flex-1 text-sm leading-relaxed text-muted">{description}</p>
      <div class="mt-5">
        <TechStack stack={stack} />
      </div>
      <span class="link-arrow mt-6">
        Case study
        <span aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</article>
