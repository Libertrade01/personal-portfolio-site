---
interface Panel {
  title: string;
  lead: string;
  leadStrong?: string;
  intro?: string;
  items?: string[];
  body?: string[];
}

interface Props {
  problem: Panel;
  goal: Panel;
}

const { problem, goal } = Astro.props;

function leadParts(panel: Panel) {
  if (!panel.leadStrong || !panel.lead.includes(panel.leadStrong)) {
    return [{ text: panel.lead, strong: false }];
  }

  const [before, after] = panel.lead.split(panel.leadStrong);

  return [
    { text: before, strong: false },
    { text: panel.leadStrong, strong: true },
    { text: after, strong: false },
  ].filter((part) => part.text.length > 0);
}
---

<section class="case-study-problem-goal" aria-label="Problem and goal">
  <article class="case-study-problem-goal__panel case-study-problem-goal__panel--problem">
    <h2 class="case-study-problem-goal__eyebrow">{problem.title}</h2>
    <p class="case-study-problem-goal__lead">
      {leadParts(problem).map((part) => (part.strong ? <strong>{part.text}</strong> : part.text))}
    </p>

    {
      problem.items && (
        <ul class="case-study-problem-goal__source-list" role="list">
          {problem.items.map((item) => <li>{item}</li>)}
        </ul>
      )
    }

    {problem.body?.map((paragraph) => <p class="case-study-problem-goal__copy">{paragraph}</p>)}
  </article>

  <article class="case-study-problem-goal__panel case-study-problem-goal__panel--goal">
    <h2 class="case-study-problem-goal__eyebrow">{goal.title}</h2>
    <p class="case-study-problem-goal__lead">
      {leadParts(goal).map((part) => (part.strong ? <strong>{part.text}</strong> : part.text))}
    </p>

    {goal.intro && <p class="case-study-problem-goal__copy">{goal.intro}</p>}

    {
      goal.items && (
        <ol class="case-study-problem-goal__question-list" role="list">
          {goal.items.map((item, index) => (
            <li>
              <span aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <p>{item}</p>
            </li>
          ))}
        </ol>
      )
    }

    {goal.body?.map((paragraph) => <p class="case-study-problem-goal__copy">{paragraph}</p>)}
  </article>
</section>

<style>
  .case-study-problem-goal {
    --case-study-navy: #1f344a;
    --case-study-navy-deep: #162a3d;
    --case-study-paper: #f7f6f1;
    --case-study-sand: #f0ebe3;
    --case-study-ink: #111827;
    --case-study-muted: #4b5563;
    --case-study-line: #d8d4ca;
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr);
    margin: 0 0 2.5rem 50%;
    transform: translateX(-50%);
    width: min(100vw - 3rem, 68rem);
  }

  .case-study-problem-goal__panel {
    border: 1px solid var(--case-study-line);
    border-radius: 1.35rem;
    box-shadow: 0 14px 44px rgba(31, 52, 74, 0.06);
    min-height: 100%;
    overflow: hidden;
    padding: clamp(1.5rem, 4vw, 2.75rem);
  }

  .case-study-problem-goal__panel--problem {
    background: linear-gradient(180deg, #f6f2eb 0%, #f3eee5 100%);
    border-color: #d7d0c3;
    color: var(--case-study-ink);
  }

  .case-study-problem-goal__panel--goal {
    background:
      linear-gradient(180deg, rgba(247, 246, 241, 0.07), rgba(247, 246, 241, 0.03)),
      var(--case-study-navy);
    border-color: rgba(31, 52, 74, 0.28);
    color: var(--case-study-paper);
  }

  .case-study-problem-goal .case-study-problem-goal__eyebrow {
    color: var(--case-study-navy);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    line-height: 1.4;
    margin: 0;
    text-transform: uppercase;
  }

  .case-study-problem-goal__panel--goal .case-study-problem-goal__eyebrow {
    color: #d7d0c3;
  }

  .case-study-problem-goal .case-study-problem-goal__lead {
    color: var(--case-study-ink);
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(1.75rem, 3.45vw, 3.35rem);
    letter-spacing: -0.035em;
    line-height: 1.02;
    margin: 1.25rem 0;
  }

  .case-study-problem-goal .case-study-problem-goal__lead strong {
    color: inherit;
    font-weight: inherit;
  }

  .case-study-problem-goal .case-study-problem-goal__panel--goal .case-study-problem-goal__lead {
    color: #fffaf2;
  }

  .case-study-problem-goal .case-study-problem-goal__copy {
    color: var(--case-study-muted);
    font-size: 0.96rem;
    line-height: 1.7;
    margin: 1rem 0 0;
    max-width: 42rem;
  }

  .case-study-problem-goal .case-study-problem-goal__panel--goal .case-study-problem-goal__copy {
    color: rgba(247, 246, 241, 0.76);
  }

  .case-study-problem-goal__source-list,
  .case-study-problem-goal__question-list {
    list-style: none;
    margin: 1.5rem 0;
    padding: 0;
  }

  .case-study-problem-goal__source-list {
    border-left: 1px solid rgba(31, 52, 74, 0.2);
    display: grid;
    gap: 0.75rem;
    padding-left: 1rem;
  }

  .case-study-problem-goal__source-list li {
    color: var(--case-study-muted);
    font-size: 0.94rem;
    line-height: 1.55;
    list-style: none;
    margin-left: 0;
  }

  .case-study-problem-goal__question-list {
    display: grid;
    gap: 0.65rem;
  }

  .case-study-problem-goal__question-list li {
    align-items: baseline;
    border-top: 1px solid rgba(247, 246, 241, 0.14);
    display: grid;
    gap: 0.85rem;
    grid-template-columns: 2rem minmax(0, 1fr);
    list-style: none;
    margin-left: 0;
    padding-top: 0.75rem;
  }

  .case-study-problem-goal__question-list span {
    color: rgba(247, 246, 241, 0.42);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
  }

  .case-study-problem-goal__question-list p {
    color: rgba(247, 246, 241, 0.84);
    font-size: 0.94rem;
    line-height: 1.5;
    margin: 0;
  }

  @media (min-width: 860px) {
    .case-study-problem-goal {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }
  }
</style>
