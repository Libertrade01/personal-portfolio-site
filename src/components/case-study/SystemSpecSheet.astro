---
interface SpecRow {
  label: string;
  description: string;
}

interface ColumnLabels {
  label: string;
  description: string;
}

interface Props {
  rows: SpecRow[];
  columns?: ColumnLabels;
}

const { rows, columns = { label: 'Label', description: 'Description' } } = Astro.props;
---

<ol class="case-study-spec-sheet" aria-label={`${columns.label} and ${columns.description}`}>
  {
    rows.map((row, index) => (
      <li class="case-study-spec-sheet__row">
        <span class="case-study-spec-sheet__index" aria-hidden="true">
          {String(index + 1).padStart(2, '0')}
        </span>
        <h3 class="case-study-spec-sheet__title">{row.label}</h3>
        <p class="case-study-spec-sheet__text">{row.description}</p>
      </li>
    ))
  }
</ol>

<style>
  .case-study-spec-sheet {
    --case-study-navy: #1f344a;
    --case-study-ink: #111827;
    --case-study-muted: #4b5563;
    --case-study-line: rgba(31, 52, 74, 0.18);
    border-bottom: 1px solid var(--case-study-line);
    list-style: none;
    margin: 1.35rem 0 1.85rem 50%;
    padding: 0;
    transform: translateX(-50%);
    width: min(100vw - 3rem, 68rem);
  }

  .case-study-spec-sheet__row {
    align-items: baseline;
    border-top: 1px solid var(--case-study-line);
    display: grid;
    gap: clamp(1rem, 2vw, 1.75rem);
    grid-template-columns: 4.25rem minmax(9rem, 0.42fr) minmax(0, 1fr);
    padding: clamp(1.05rem, 2.1vw, 1.55rem) 0;
  }

  .case-study-spec-sheet__index {
    color: rgba(31, 52, 74, 0.34);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.76rem;
    letter-spacing: 0.1em;
    line-height: 1.4;
  }

  .case-study-spec-sheet .case-study-spec-sheet__title {
    color: var(--case-study-ink);
    font-family: var(--font-sans, system-ui, sans-serif);
    font-size: clamp(1rem, 1.4vw, 1.18rem);
    font-weight: 650;
    line-height: 1.25;
    margin: 0;
  }

  .case-study-spec-sheet .case-study-spec-sheet__text {
    color: var(--case-study-muted);
    font-size: clamp(0.98rem, 1.2vw, 1.06rem);
    line-height: 1.68;
    margin: 0;
  }

  @media (max-width: 720px) {
    .case-study-spec-sheet__row {
      align-items: start;
      gap: 0.4rem 1rem;
      grid-template-columns: 3.5rem minmax(0, 1fr);
      padding: 1.15rem 0;
    }

    .case-study-spec-sheet__text {
      grid-column: 2;
    }
  }
</style>
