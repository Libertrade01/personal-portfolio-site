---
interface Shot {
  image: string;
  alt: string;
  label?: string;
}

interface Props {
  heading?: string;
  shots: Shot[];
  idPrefix?: string;
}

const { heading = 'Snapshots', shots, idPrefix = 'snapshot' } = Astro.props;
const headingId = `${idPrefix}-heading`;
const hasMultipleShots = shots.length > 1;
---

<section class="case-study-snapshots" aria-labelledby={headingId} data-snapshot-carousel>
  <header class="case-study-snapshots__header">
    <h2 id={headingId} class="case-study-snapshots__heading">{heading}</h2>
  </header>

  <div class="case-study-snapshots__track" tabindex={hasMultipleShots ? 0 : undefined} data-snapshot-track>
    {
      shots.map((shot, index) => (
        <figure class="case-study-snapshots__slide" id={`${idPrefix}-${index + 1}`} data-snapshot-slide>
          <div class="case-study-snapshots__image-frame">
            <img src={shot.image} alt={shot.alt} loading="lazy" decoding="async" />
          </div>
          {shot.label && (
            <figcaption class="case-study-snapshots__caption">
              <span>{String(index + 1).padStart(2, '0')}</span>
              {shot.label}
            </figcaption>
          )}
        </figure>
      ))
    }
  </div>

  {
    hasMultipleShots && (
      <nav class="case-study-snapshots__nav" aria-label="Snapshot navigation">
        {shots.map((shot, index) => (
          <a
            href={`#${idPrefix}-${index + 1}`}
            aria-current={index === 0 ? 'true' : undefined}
            aria-label={`View ${shot.label ?? `snapshot ${index + 1}`}`}
            data-snapshot-indicator
          >
            <span>{String(index + 1).padStart(2, '0')}</span>
          </a>
        ))}
      </nav>
    )
  }
</section>

<style>
  .case-study-snapshots {
    --case-study-navy: var(--ml-ink);
    --case-study-ink: var(--ml-ink);
    --case-study-sand: var(--ml-paper-deep);
    --case-study-paper: var(--ml-paper-raised);
    --case-study-line: var(--ml-line);
    --case-study-muted: var(--ml-muted);
    margin: clamp(5rem, 9vw, 8rem) auto 0;
    width: min(100%, 72rem);
  }

  .case-study-snapshots__header {
    margin-bottom: clamp(1.4rem, 3vw, 2rem);
  }

  .case-study-snapshots .case-study-snapshots__heading {
    color: var(--case-study-ink);
    font-family: var(--font-sans);
    font-size: clamp(2.15rem, 4.6vw, 4.2rem);
    font-weight: 400;
    letter-spacing: -0.055em;
    line-height: 0.95;
    margin: 0;
    max-width: 13ch;
  }

  .case-study-snapshots__track {
    display: flex;
    gap: clamp(1rem, 2.4vw, 1.6rem);
    overflow-x: auto;
    padding: 0 0 0.85rem;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-color: var(--ml-line-strong) transparent;
  }

  .case-study-snapshots__track:focus-visible {
    outline: 2px solid var(--ml-line-strong);
    outline-offset: 0.35rem;
  }

  .case-study-snapshots__slide {
    flex: 0 0 min(88vw, 64rem);
    margin: 0;
    scroll-margin-inline: 1rem;
    scroll-snap-align: center;
  }

  .case-study-snapshots__image-frame {
    background: var(--case-study-sand);
    border: 1px solid var(--case-study-line);
    border-radius: 0.5rem;
    overflow: hidden;
    padding: clamp(0.5rem, 1.4vw, 0.8rem);
  }

  .case-study-snapshots__image-frame img {
    background: var(--case-study-paper);
    border-radius: 0.35rem;
    display: block;
    height: auto;
    width: 100%;
  }

  .case-study-snapshots__caption {
    align-items: center;
    color: var(--case-study-muted);
    display: flex;
    gap: 0.7rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    line-height: 1.5;
    margin-top: 0.85rem;
    text-transform: uppercase;
  }

  .case-study-snapshots__caption span {
    color: var(--ml-muted);
  }

  .case-study-snapshots__nav {
    align-items: center;
    display: flex;
    gap: 0.55rem;
    justify-content: center;
    margin-top: 0.45rem;
  }

  .case-study-snapshots__nav a {
    align-items: center;
    border: 1px solid var(--ml-line);
    border-radius: 999px;
    color: var(--ml-muted);
    display: inline-flex;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.65rem;
    height: 1.8rem;
    justify-content: center;
    letter-spacing: 0.08em;
    min-width: 2.4rem;
    text-decoration: none;
  }

  .case-study-snapshots__nav a:hover,
  .case-study-snapshots__nav a:focus-visible,
  .case-study-snapshots__nav a[aria-current='true'] {
    background: var(--case-study-navy);
    border-color: var(--case-study-navy);
    color: #f7f6f1;
  }

  @media (max-width: 720px) {
    .case-study-snapshots {
      margin-top: 4rem;
      width: 100%;
    }

    .case-study-snapshots__slide {
      flex-basis: min(86vw, 64rem);
      scroll-snap-align: start;
    }
  }
</style>

<script>
  const carousels = document.querySelectorAll<HTMLElement>('[data-snapshot-carousel]');

  carousels.forEach((carousel) => {
    if (carousel.dataset.snapshotCarouselEnhanced === 'true') return;

    const track = carousel.querySelector<HTMLElement>('[data-snapshot-track]');
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>('[data-snapshot-slide]'));
    const indicators = Array.from(carousel.querySelectorAll<HTMLElement>('[data-snapshot-indicator]'));

    if (!track || slides.length < 2 || indicators.length === 0) return;

    carousel.dataset.snapshotCarouselEnhanced = 'true';

    const setActiveIndicator = (activeIndex: number) => {
      indicators.forEach((indicator, index) => {
        if (index === activeIndex) {
          indicator.setAttribute('aria-current', 'true');
        } else {
          indicator.removeAttribute('aria-current');
        }
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const activeIndex = slides.indexOf(entry.target as HTMLElement);
          if (activeIndex >= 0) setActiveIndicator(activeIndex);
        });
      },
      { root: track, threshold: 0.62 },
    );

    slides.forEach((slide) => observer.observe(slide));
  });
</script>
