---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import type { ProjectEntry } from '../../utils/content';

interface Props {
  project: ProjectEntry;
}

const { project } = Astro.props;
const {
  title,
  description,
  descriptionExtra,
  liveUrl,
  liveLabel = 'View live site',
  liveCtaNote,
  coverImage,
  coverFit,
  coverPosition,
  coverFrame,
  coverFrameLabel,
  showHeroCover,
  github,
  caseOverview,
} = project.data;

const coverRetina = coverImage?.replace(/\.(png|jpe?g|webp)$/i, '@2x.$1');
const hasRetinaCover =
  Boolean(coverImage && coverRetina) &&
  existsSync(join(process.cwd(), 'public', coverRetina!.replace(/^\//, '')));
---

<header class="case-study-hero">
  <div class="container-main">
    <div class={`case-study-hero__copy${caseOverview ? ' case-study-hero__copy--overview' : ''}`}>
      <p class="case-study-hero__label">Project case study</p>
      <h1>{title}</h1>

      {
        caseOverview ? (
          <div class="case-study-hero__overview">
            <div class="case-study-hero__overview-copy">
              <p class="case-study-hero__lede">{caseOverview.lead}</p>
              <p class="case-study-hero__overview-body">{caseOverview.body}</p>
              {caseOverview.note && <p class="case-study-hero__overview-note">{caseOverview.note}</p>}

              <div class="case-study-hero__actions">
                {liveUrl && (
                  <a class="case-study-hero__demo-cta" href={liveUrl} target="_blank" rel="noopener noreferrer">
                    <span>
                      {liveLabel} <span aria-hidden="true">&rarr;</span>
                    </span>
                    {liveCtaNote && <small>{liveCtaNote}</small>}
                  </a>
                )}
                {github && (
                  <a class="case-study-hero__source-link" href={github} target="_blank" rel="noopener noreferrer">
                    View source <span aria-hidden="true">↗</span>
                  </a>
                )}
              </div>
            </div>

            <dl class="case-study-hero__facts">
              {caseOverview.facts.map((fact) => (
                <div>
                  <dt>{fact.label}</dt>
                  <dd>{fact.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        ) : (
          <>
            <p class="case-study-hero__lede">{description}</p>
            {descriptionExtra && <p class="case-study-hero__intro">{descriptionExtra}</p>}

            <div class="case-study-hero__actions">
              {liveUrl && (
                <a class="case-study-hero__demo-cta" href={liveUrl} target="_blank" rel="noopener noreferrer">
                  <span>
                    {liveLabel} <span aria-hidden="true">&rarr;</span>
                  </span>
                  {liveCtaNote && <small>{liveCtaNote}</small>}
                </a>
              )}
              {github && (
                <a class="case-study-hero__source-link" href={github} target="_blank" rel="noopener noreferrer">
                  View source <span aria-hidden="true">↗</span>
                </a>
              )}
            </div>
          </>
        )
      }
    </div>

    {
      coverImage && showHeroCover && (
        <div
          class={`case-study-hero__artifact${coverFrame ? ` case-study-hero__artifact--${coverFrame}` : ''}`}
        >
          {coverFrame && (
            <div class="product-frame__bar" aria-hidden="true">
              <span class="product-frame__dots"><i></i><i></i><i></i></span>
              <span class="product-frame__label">{coverFrameLabel ?? title}</span>
              <span></span>
            </div>
          )}
          <div class="case-study-hero__artifact-media">
            {
              hasRetinaCover ? (
                <picture>
                  <source srcset={`${coverRetina} 2x`} type="image/png" />
                  <img
                    src={coverImage}
                    srcset={`${coverImage} 1x, ${coverRetina} 2x`}
                    alt={`${title} cover`}
                    loading="eager"
                    decoding="async"
                    sizes="(min-width: 1152px) 1152px, 100vw"
                    style={`object-fit: ${coverFit ?? 'cover'}; object-position: ${coverPosition ?? 'center'};`}
                  />
                </picture>
              ) : (
                <img
                  src={coverImage}
                  alt={`${title} cover`}
                  loading="eager"
                  decoding="async"
                  style={`object-fit: ${coverFit ?? 'cover'}; object-position: ${coverPosition ?? 'center'};`}
                />
              )
            }
          </div>
        </div>
      )
    }
  </div>
</header>

<style>
  .case-study-hero {
    background: var(--ml-paper);
    border-bottom: 1px solid var(--ml-line);
    color: var(--ml-ink);
    padding: clamp(4rem, 8vw, 7.5rem) 0 2.5rem;
  }

  .case-study-hero :global(.container-main) {
    width: var(--ml-shell);
    max-width: none;
    padding-inline: 0;
  }

  .case-study-hero__label {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.68rem;
    letter-spacing: 0.13em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .case-study-hero__label {
    color: var(--ml-muted);
    margin: 0;
  }

  .case-study-hero__copy {
    max-width: 920px;
  }

  .case-study-hero__copy--overview {
    max-width: none;
  }

  .case-study-hero h1 {
    color: var(--ml-ink);
    font-family: var(--font-sans);
    font-size: clamp(3rem, 7vw, 6.6rem);
    font-weight: 400;
    letter-spacing: -0.065em;
    line-height: 0.95;
    margin: 1rem 0 0;
    max-width: 920px;
    text-wrap: balance;
  }

  .case-study-hero__lede {
    color: var(--ml-ink-soft);
    font-size: clamp(1.1rem, 2vw, 1.42rem);
    font-weight: 300;
    line-height: 1.55;
    margin: 1.5rem 0 0;
    max-width: 800px;
  }

  .case-study-hero__intro {
    border-left: 1px solid var(--ml-line-strong);
    color: var(--ml-muted);
    font-size: 1rem;
    line-height: 1.75;
    margin: 1.25rem 0 0;
    max-width: 780px;
    padding-left: 1.15rem;
  }

  .case-study-hero__overview {
    display: grid;
    gap: clamp(2rem, 5vw, 4.5rem);
    margin-top: clamp(1.75rem, 4vw, 3rem);
  }

  .case-study-hero__overview .case-study-hero__lede {
    margin-top: 0;
    max-width: 42rem;
  }

  .case-study-hero__overview-body {
    color: var(--ml-ink-soft);
    font-size: clamp(0.98rem, 1.2vw, 1.08rem);
    font-weight: 300;
    line-height: 1.65;
    margin: 1.2rem 0 0;
    max-width: 46rem;
  }

  .case-study-hero__overview-note {
    color: var(--ml-muted);
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 1.6;
    margin: 1.15rem 0 0;
    max-width: 42rem;
  }

  .case-study-hero__facts {
    border-top: 1px solid var(--ml-line);
    display: grid;
    gap: 0;
    margin: 0;
  }

  .case-study-hero__facts > div {
    border-bottom: 1px solid var(--ml-line);
    display: grid;
    gap: 0.35rem;
    padding: 0.95rem 0;
  }

  .case-study-hero__facts dt {
    color: var(--ml-muted);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .case-study-hero__facts dd {
    color: var(--ml-ink);
    font-size: 0.92rem;
    font-weight: 400;
    line-height: 1.45;
    margin: 0;
  }

  .case-study-hero__actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.6rem;
  }

  .case-study-hero__demo-cta {
    align-items: center;
    background: var(--ml-ink);
    border: 1px solid var(--ml-ink);
    border-radius: 0.35rem;
    box-shadow: 0 10px 26px rgba(31, 31, 28, 0.12);
    color: var(--ml-paper);
    display: inline-flex;
    flex-direction: column;
    font-family: var(--font-mono, ui-monospace, monospace);
    gap: 0.3rem;
    letter-spacing: 0.12em;
    padding: 0.95rem 1.2rem;
    text-transform: uppercase;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .case-study-hero__demo-cta:hover {
    background: var(--ml-ink-soft);
    border-color: var(--ml-ink-soft);
    transform: translateY(-1px);
  }

  .case-study-hero__demo-cta span {
    align-items: center;
    display: inline-flex;
    font-size: 0.78rem;
    font-weight: 600;
    gap: 0.45rem;
  }

  .case-study-hero__demo-cta small {
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
  }

  .case-study-hero__source-link {
    color: var(--ml-ink-soft);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .case-study-hero__source-link:hover {
    color: var(--ml-clay);
  }

  .case-study-hero__artifact {
    background: var(--ml-paper-deep);
    border: 1px solid var(--ml-line);
    border-radius: 0.5rem;
    margin: 2.5rem 0 0;
    overflow: hidden;
    padding: clamp(0.65rem, 1.5vw, 1.25rem);
  }

  .case-study-hero__artifact--browser,
  .case-study-hero__artifact--window {
    background: #e9e7e1;
    border-color: rgba(48, 47, 43, 0.22);
    border-radius: 0.55rem;
    box-shadow: 0 0.8rem 2rem rgba(48, 47, 43, 0.08);
    padding: 0;
  }

  .product-frame__bar {
    align-items: center;
    background: rgba(48, 47, 43, 0.035);
    border-bottom: 1px solid rgba(48, 47, 43, 0.14);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    min-height: 2rem;
    padding: 0 0.75rem;
  }

  .product-frame__dots {
    display: flex;
    gap: 0.3rem;
  }

  .product-frame__dots i {
    background: rgba(48, 47, 43, 0.28);
    border-radius: 50%;
    display: block;
    height: 0.38rem;
    width: 0.38rem;
  }

  .case-study-hero__artifact--window .product-frame__dots i:first-child {
    background: rgba(143, 74, 54, 0.58);
  }

  .product-frame__label {
    color: var(--ml-muted);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.58rem;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .case-study-hero__artifact-media,
  .case-study-hero__artifact picture {
    display: block;
  }

  .case-study-hero__artifact img {
    display: block;
    width: 100%;
    border-radius: 0.35rem;
  }

  .case-study-hero__artifact--browser img,
  .case-study-hero__artifact--window img {
    border-radius: 0;
  }

  @media (min-width: 860px) {
    .case-study-hero__overview {
      grid-template-columns: minmax(0, 1.35fr) minmax(14rem, 0.75fr);
    }
  }

  @media (max-width: 640px) {
    .case-study-hero {
      padding-bottom: 1.5rem;
    }

    .case-study-hero__demo-cta {
      width: 100%;
    }
  }
</style>
