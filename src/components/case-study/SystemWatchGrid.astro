---
interface WatchItem {
  title: string;
  description: string;
}

interface Props {
  heading?: string;
  items: WatchItem[];
}

const { heading = 'Features', items } = Astro.props;
const headingId = 'case-study-watch-grid-heading';
---

<section class="case-study-watch" aria-labelledby={headingId}>
  <header class="case-study-watch__header">
    <h2 id={headingId} class="case-study-watch__heading">{heading}</h2>
  </header>

  <div class="case-study-watch-grid" aria-label="System watch signals">
    {
      items.map((item, index) => (
        <article class="case-study-watch-grid__card">
          <span class="case-study-watch-grid__index" aria-hidden="true">
            [{String(index + 1).padStart(2, '0')}]
          </span>
          <h3 class="case-study-watch-grid__title">{item.title}</h3>
          <p class="case-study-watch-grid__text">{item.description}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .case-study-watch {
    --case-study-ink: var(--ml-ink);
    margin: clamp(5rem, 9vw, 8rem) auto 1.75rem;
    width: min(100%, 72rem);
  }

  .case-study-watch__header {
    margin-bottom: clamp(1.4rem, 3vw, 2rem);
  }

  .case-study-watch .case-study-watch__heading {
    color: var(--case-study-ink);
    font-family: var(--font-sans);
    font-size: clamp(2.15rem, 4.6vw, 4.2rem);
    font-weight: 400;
    letter-spacing: -0.055em;
    line-height: 0.95;
    margin: 0;
    max-width: 13ch;
  }

  .case-study-watch-grid {
    --case-study-navy: var(--ml-ink);
    --case-study-muted: var(--ml-muted);
    --case-study-line: var(--ml-line);
    --case-study-paper: var(--ml-paper-raised);
    display: grid;
    gap: 1px;
    grid-template-columns: minmax(0, 1fr);
    margin: 0 auto;
    width: min(100%, 68rem);
  }

  .case-study-watch-grid__card {
    background: color-mix(in srgb, var(--ml-paper-raised) 84%, transparent);
    border: 1px solid var(--case-study-line);
    box-shadow: none;
    min-height: 13rem;
    padding: clamp(1.25rem, 2.5vw, 1.8rem);
  }

  .case-study-watch-grid__index {
    align-items: center;
    background: transparent;
    border: 1px solid var(--ml-line);
    border-radius: 999px;
    color: var(--ml-muted);
    display: inline-flex;
    font-family: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1;
    margin-bottom: 1rem;
    padding: 0.275rem 0.5rem;
  }

  .case-study-watch-grid .case-study-watch-grid__title {
    color: var(--case-study-navy);
    font-family: var(--font-sans);
    font-size: clamp(1.55rem, 2.7vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.02;
    margin: 0 0 0.85rem;
  }

  .case-study-watch-grid .case-study-watch-grid__text {
    color: var(--case-study-muted);
    font-size: 0.92rem;
    line-height: 1.6;
    margin: 0;
  }

  @media (min-width: 680px) {
    .case-study-watch-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1080px) {
    .case-study-watch-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .case-study-watch {
      margin-top: 4rem;
      width: 100%;
    }
  }
</style>
