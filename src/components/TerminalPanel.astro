---
import { hero } from '../config/site';

interface Props {
  large?: boolean;
  filename?: string;
}

const { large = false, filename = hero.terminal.filename } = Astro.props;
---

<div
  class:list={[
    'relative overflow-hidden rounded-2xl border border-border bg-charcoal glow-amber',
    large && 'rounded-3xl',
  ]}
>
  <div
    class:list={[
      'flex items-center gap-2 border-b border-border bg-charcoal-light/80 px-4',
      large ? 'py-3' : 'py-2.5',
    ]}
  >
    <span class="h-2.5 w-2.5 rounded-full bg-white/10"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-white/10"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-white/10"></span>
    <span class:list={['ml-2 font-mono text-muted', large ? 'text-xs' : 'text-[10px]']}>{filename}</span>
  </div>
  <div class:list={['font-mono leading-relaxed', large ? 'px-6 py-8 text-base md:text-lg lg:text-xl' : 'px-4 py-4 text-[11px]']}>
    <p class="text-muted">
      <span class="text-emerald-500/90">→</span>
      <span class="text-amber-accent/90"> input</span><span class="text-muted">.normalize()</span>
      <span class="text-off-white/50"> → </span>
      <span class="text-amber-accent/90">output</span><span class="text-muted">.structured()</span>
      <span
        class:list={[
          'ml-1 inline-block animate-[blink_1s_step-end_infinite] bg-amber-bright',
          large ? 'h-5 w-2' : 'h-3.5 w-1.5',
        ]}
        aria-hidden="true"
      ></span>
    </p>
  </div>
  <div
    class="pointer-events-none absolute -inset-px rounded-[inherit] opacity-60"
    style="background: radial-gradient(ellipse at 50% 100%, rgba(var(--accent-rgb),0.12), transparent 65%);"
    aria-hidden="true"
  >
  </div>
</div>
