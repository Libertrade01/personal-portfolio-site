---
interface Feature {
  title: string;
  description: string;
}

interface Props {
  features: Feature[];
}

const { features } = Astro.props;
---

<div class="my-8 grid gap-4 sm:grid-cols-2">
  {
    features.map((f) => (
      <div class="card-surface p-5">
        <h3 class="text-sm font-medium text-off-white">{f.title}</h3>
        <p class="mt-2 text-sm text-muted">{f.description}</p>
      </div>
    ))
  }
</div>
