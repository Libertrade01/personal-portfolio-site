---
interface Props {
  steps: string[];
  title?: string;
}

const { steps, title } = Astro.props;
---

<div class="my-8">
  {title && <p class="mb-6 section-label">{title}</p>}
  <div class="relative">
    <!-- Connecting line (desktop) -->
    <div
      class="absolute left-0 right-0 top-1/2 hidden h-px -translate-y-1/2 md:block"
      style="background: linear-gradient(90deg, transparent, rgba(var(--accent-rgb),0.25) 15%, rgba(var(--accent-rgb),0.25) 85%, transparent);"
      aria-hidden="true"
    >
    </div>

    <div class="relative grid gap-4 md:grid-cols-4 md:gap-3">
      {
        steps.map((step, i) => (
          <div class="card-surface group relative p-5 md:p-6">
            <div class="mb-4 flex h-8 w-8 items-center justify-center rounded-full border border-amber-accent/30 bg-amber-accent/10 font-mono text-xs text-amber-accent transition group-hover:border-amber-accent/60 group-hover:bg-amber-accent/20">
              {i + 1}
            </div>
            <p class="text-sm leading-relaxed text-off-white">{step}</p>
            {i < steps.length - 1 && (
              <span
                class="absolute -right-2 top-1/2 hidden -translate-y-1/2 font-mono text-amber-accent/40 md:inline"
                aria-hidden="true"
              >
                →
              </span>
            )}
          </div>
        ))
      }
    </div>
  </div>
</div>
