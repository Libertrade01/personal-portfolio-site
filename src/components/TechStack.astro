---
interface Props {
  stack: string[];
}

const { stack } = Astro.props;
---

<div class="flex flex-wrap gap-1.5">
  {
    stack.map((tech) => (
      <span
        class="rounded-md border border-border/80 bg-charcoal/60 px-2.5 py-1 font-mono text-[10px] uppercase tracking-wide text-muted transition hover:border-amber-accent/20 hover:text-amber-accent/80"
      >
        {tech}
      </span>
    ))
  }
</div>
