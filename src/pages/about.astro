---
import Layout from '../components/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { site, about } from '../config/site';

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  jobTitle: 'AI Workflow Builder & Systems Operator',
  url: site.url,
  sameAs: [site.github, site.linkedin],
  description: site.description,
  image: new URL(site.headshot, site.url).href,
};
---

<Layout title={`About — ${site.name}`} description="How Michael Low works, what he builds, and who he works with.">
  <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
  <PageHeader
    label="About"
    title="Michael Low"
    subtitle="Practical AI systems for messy, real-world workflows."
  />

  <section class="section-padding">
    <div class="container-main max-w-3xl">
      <div class="flex flex-col gap-10 md:flex-row md:items-start">
        <div class="shrink-0 mx-auto md:mx-0">
          <div
            class="h-36 w-36 overflow-hidden rounded-2xl border border-amber-accent/15 bg-charcoal-card shadow-lg glow-amber md:h-44 md:w-44"
          >
            <img
              src={site.headshot}
              alt={`${site.name} — headshot`}
              class="h-full w-full object-cover object-[center_20%]"
              width={176}
              height={176}
              loading="eager"
              onerror={`this.onerror=null;this.src='${site.headshotFallback}';`}
            />
          </div>
        </div>

        <div class="space-y-5 text-muted md:pt-2">
          <p class="font-sans text-lg leading-relaxed text-off-white/90">
            I'm <strong class="text-off-white">Michael Low</strong>. I build practical AI systems for
            messy real-world workflows.
          </p>
          {about.paragraphs.map((p) => <p class="leading-relaxed">{p}</p>)}
          <p class="font-mono text-sm text-amber-accent/90">{site.tagline}</p>
        </div>
      </div>

      <div class="mt-16">
        <p class="section-label">How I show up</p>
        <div class="mt-6 space-y-4 font-mono text-sm leading-relaxed">
          {
            about.traits.map((t) => (
              <p>
                <span class="text-amber-accent">{t.label}</span>
                <span class="text-muted"> / {t.detail}</span>
              </p>
            ))
          }
        </div>
      </div>

      <div class="mt-16">
        <p class="section-label">Beyond work</p>
        <p class="mt-4 leading-relaxed text-muted">{about.personal}</p>
      </div>
    </div>
  </section>
</Layout>
