---
import Layout from '../components/Layout.astro';
import { site, about } from '../config/site';

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  jobTitle: 'AI Product Builder & Systems Designer',
  url: site.url,
  sameAs: [site.github, site.linkedin],
  description: site.shortBio,
  image: new URL(site.headshot, site.url).href,
};
---

<Layout title={`About — ${site.name}`} description="How Michael Low thinks, works and builds practical AI systems.">
  <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
  <div class="inner-v2 about-v2">
    <section class="about-v2__intro" aria-labelledby="about-title">
      <div class="home-v2-shell about-v2__intro-grid">
        <figure class="about-v2__photo">
          <div class="about-v2__frame">
            <img
              src={`${site.headshotCutout}?v=6`}
              alt={`${site.name} portrait`}
              width="1024"
              height="959"
              loading="eager"
              decoding="async"
            />
          </div>
        </figure>

        <div class="about-v2__intro-copy">
          <p class="home-v2-kicker">About</p>
          <h1 id="about-title">I make complicated work easier to operate.</h1>
          <p class="about-v2__lede">
            I work between product design, engineering and operations, usually where the problem is still ambiguous and the workflow has not been properly defined yet.
          </p>
          <div class="about-v2__meta">
            <span>Based in São Paulo · Working globally</span>
            <span>Open to AI product &amp; systems roles</span>
          </div>
        </div>
      </div>
    </section>

    <section class="about-v2__story">
      <div class="home-v2-shell about-v2__story-grid">
        <div class="about-v2__copy">
          <p class="home-v2-kicker">The work</p>
          {about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>
    </section>

    <section class="about-v2__principles">
      <div class="home-v2-shell">
        <header>
          <p class="home-v2-kicker">How I show up</p>
          <h2>Practical by default.</h2>
        </header>
        <div class="about-v2__principle-list">
          {about.traits.map((trait, index) => (
            <article>
              <span>0{index + 1}</span>
              <h3>{trait.label}</h3>
              <p>{trait.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="about-v2__personal">
      <div class="home-v2-shell">
        <p class="home-v2-kicker">Beyond the work</p>
        <p>{about.personal}</p>
      </div>
    </section>
  </div>
</Layout>
