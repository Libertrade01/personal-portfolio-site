---
import Layout from '../components/Layout.astro';
import { site, about } from '../config/site';
import { getFeaturedProjects } from '../utils/content';

const featured = await getFeaturedProjects();
const priority = [
  'libertrade-journal-analytics',
  'trading-knowledge-wiki',
  'book-inmobiliaria',
];
const systems = priority
  .map((slug) => featured.find((project) => project.slug === slug))
  .filter((project) => Boolean(project));

const process = [
  {
    title: 'Observe',
    description:
      'Map the real workflow — including the awkward workarounds people have learned to ignore.',
  },
  {
    title: 'Simplify',
    description:
      'Cut the problem down to the decisions, information and hand-offs that actually matter.',
  },
  {
    title: 'Build',
    description:
      'Ship a usable product or operating layer people can run without constant explanation.',
  },
  {
    title: 'Iterate',
    description:
      'Watch it in use, find the friction, and refine until the structure feels inevitable.',
  },
];

const proofPoints = [
  {
    label: 'Systems shipped',
    value: 'End-to-end',
    detail: 'From messy input to a product people can operate on a normal Tuesday.',
  },
  {
    label: 'Focus',
    value: 'AI + workflow',
    detail: 'Products that organise dense information and make the next decision obvious.',
  },
  {
    label: 'Stack depth',
    value: 'Full build',
    detail: 'Product design, AI-assisted flows, Next.js / Astro, Supabase, CMS architecture.',
  },
];

const skills = [
  { group: 'Product', items: ['Product design', 'Information architecture', 'Decision-centred UX'] },
  { group: 'AI systems', items: ['AI-assisted workflows', 'Knowledge systems', 'Retrieval & notes ops'] },
  { group: 'Engineering', items: ['Next.js & Astro', 'Supabase', 'Automation & CMS'] },
];
---

<Layout
  title="Michael Low — Practical AI systems for messy workflows"
  description="Michael Low designs and builds practical AI products, knowledge systems, and automation for information-heavy work."
>
  <div class="mock">
    <section class="mock-hero" aria-labelledby="mock-hero-title">
      <div class="mock-shell mock-hero__grid">
        <div class="mock-hero__copy">
          <p class="mock-kicker">Applied AI · Workflow systems · Product engineering</p>
          <h1 id="mock-hero-title">Practical AI<br />Systems for<br />Messy Manual<br />Workflows.</h1>
          <p class="mock-hero__intro">
            I design and build AI-powered products, knowledge systems and automation that make complex work simpler.
          </p>
          <div class="mock-actions">
            <a class="mock-button mock-button--primary" href="#systems">Explore the systems</a>
            <a class="mock-text-link" href="#process">How I work <span aria-hidden="true">↓</span></a>
          </div>
        </div>

        <figure class="mock-refinement">
          <img
            src="/images/neural-system-hero.png"
            alt="An intricate spherical network of connected nodes and paths"
            width="1254"
            height="1254"
            loading="eager"
            decoding="async"
          />
        </figure>
      </div>

    </section>

    <!-- NEW: quick proof strip for hiring managers skimming -->
    <section class="mock-proof" aria-label="At a glance">
      <div class="mock-shell mock-proof__grid">
        {proofPoints.map((point) => (
          <article>
            <p class="mock-kicker">{point.label}</p>
            <h2>{point.value}</h2>
            <p>{point.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- SYSTEMS: editorial / asymmetric — not a stacked card list -->
    <section id="systems" class="mock-section mock-systems" aria-labelledby="systems-title">
      <div class="mock-shell">
        <header class="mock-systems__head">
          <p class="mock-kicker">Selected systems</p>
          <div class="mock-systems__head-row">
            <h2 id="systems-title">Work that shows how I think and ship.</h2>
            <p>
              Three products that organise dense information and prove I can take a messy problem all the way to a usable system.
            </p>
          </div>
        </header>

        {systems[0] && (
          <article class="mock-feature">
            <a href={`/projects/${systems[0].slug}`} aria-label={`Read the ${systems[0].data.title} case study`}>
              <div class="mock-feature__visual">
                {systems[0].data.coverImage ? (
                  <img
                    src={systems[0].data.coverImage}
                    alt={`${systems[0].data.title} interface`}
                    loading="lazy"
                    decoding="async"
                  />
                ) : null}
              </div>
              <div class="mock-feature__copy">
                <div class="mock-feature__meta">
                  <span>{systems[0].data.category}</span>
                  <span>{systems[0].data.status}</span>
                </div>
                <h3>{systems[0].data.title}</h3>
                <p>{systems[0].data.description}</p>
                <ul aria-label={`${systems[0].data.title} technologies`}>
                  {systems[0].data.stack.slice(0, 4).map((item) => <li>{item}</li>)}
                </ul>
                <span class="mock-feature__view">
                  Read case study <span aria-hidden="true">↗</span>
                </span>
              </div>
            </a>
          </article>
        )}

        <div class="mock-pair">
          {systems.slice(1).map((project, index) => {
            if (!project) return null;
            const number = String(index + 2).padStart(2, '0');
            const { title, description, coverImage, stack, category, status } = project.data;
            return (
              <article class:list={['mock-pair__item', index === 1 && 'mock-pair__item--offset']}>
                <a href={`/projects/${project.slug}`} aria-label={`Read the ${title} case study`}>
                  <div class="mock-pair__visual">
                    {coverImage ? (
                      <img src={coverImage} alt={`${title} interface`} loading="lazy" decoding="async" />
                    ) : (
                      <span>{title}</span>
                    )}
                  </div>
                  <div class="mock-pair__copy">
                    <div class="mock-pair__meta">
                      <span>{number}</span>
                      <span>{category}</span>
                      <span>{status}</span>
                    </div>
                    <h3>{title}</h3>
                    <p>{description}</p>
                    <ul aria-label={`${title} technologies`}>
                      {stack.slice(0, 3).map((item) => <li>{item}</li>)}
                    </ul>
                    <span class="mock-pair__view">
                      Case study <span aria-hidden="true">↗</span>
                    </span>
                  </div>
                </a>
              </article>
            );
          })}
        </div>

        <div class="mock-section-action">
          <a class="mock-text-link" href="/projects">View all systems <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    <!-- ABOUT: compact trust layer for hiring managers -->
    <section id="about" class="mock-section mock-about" aria-labelledby="about-title">
      <div class="mock-shell mock-about__layout">
        <figure class="mock-about__photo">
          <div class="mock-about__cutout">
            <img
              src={`${site.headshotCutout}?v=12`}
              alt={`${site.name} portrait`}
              width="1024"
              height="978"
              loading="lazy"
              decoding="async"
            />
          </div>
          <figcaption>Michael Low · São Paulo</figcaption>
        </figure>

        <div class="mock-about__copy">
          <p class="mock-kicker">About</p>
          <h2 id="about-title">I make complicated work easier to operate.</h2>
          <p>
            I work between product design, engineering and operations — usually where the problem is still ambiguous and the workflow has not been properly defined yet.
          </p>
          <p>
            {about.paragraphs[0]} {about.paragraphs[1]}
          </p>
          <div class="mock-about__meta">
            <span>Based in São Paulo · Working globally</span>
            <span>Open to AI product &amp; systems roles</span>
            <a href="/about">Full about page <span aria-hidden="true">→</span></a>
          </div>
        </div>
      </div>
    </section>

    <!-- SKILLS: made prominent for AI hiring managers -->
    <section id="skills" class="mock-section mock-skills" aria-labelledby="skills-title">
      <div class="mock-shell mock-skills__layout">
        <header>
          <p class="mock-kicker">Capabilities</p>
          <h2 id="skills-title">What I bring to an AI team.</h2>
          <p>
            Not slide decks — shipped systems. Comfortable across product, AI workflow design and the engineering needed to make them real.
          </p>
        </header>
        <div class="mock-skills__groups">
          {skills.map((skill) => (
            <div class="mock-skill-group">
              <p class="mock-kicker">{skill.group}</p>
              <ul>
                {skill.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section id="process" class="mock-section mock-process" aria-labelledby="process-title">
      <div class="mock-shell mock-process__layout">
        <header class="mock-process__intro">
          <p class="mock-kicker">How I work</p>
          <h2 id="process-title">Refinement is the work.</h2>
          <p>
            I rarely start with a clean specification. I start with scattered information, repeated friction and a problem that has not been properly framed yet.
          </p>
        </header>
        <ol class="mock-process__steps">
          {process.map((step, index) => (
            <li>
              <span>0{index + 1}</span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- CONTACT: job-seeking framing -->
    <section id="contact" class="mock-contact" aria-labelledby="contact-title">
      <div class="mock-shell mock-contact__inner">
        <div>
          <p class="mock-kicker">Next step</p>
          <h2 id="contact-title">Looking for someone who can turn messy AI problems into working systems?</h2>
        </div>
        <div class="mock-contact__copy">
          <p>
            Open to AI product, workflow and systems roles — remote or hybrid — where the work is shipping useful software, not theatre.
          </p>
          <div class="mock-contact__actions">
            <a class="mock-button mock-button--light" href={`mailto:${site.email}`}>
              Email me <span aria-hidden="true">↗</span>
            </a>
            <a class="mock-text-link mock-text-link--on-dark" href={site.linkedin} target="_blank" rel="noopener noreferrer">
              LinkedIn <span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .mock {
    --paper: #f4f0e8;
    --raised: #faf7f1;
    --deep: #e9e2d7;
    --ink: #1d1f1e;
    --soft: #454744;
    --muted: #77756f;
    --line: rgba(48, 47, 43, 0.14);
    --line-strong: rgba(48, 47, 43, 0.24);
    --signal: #3d5a4c;
    color: var(--ink);
    background: var(--paper);
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
  }

  .mock a {
    text-decoration: none;
  }

  .mock a:not(.mock-button) {
    color: inherit;
  }

  .mock-shell {
    width: min(92rem, calc(100% - 3rem));
    margin-inline: auto;
  }

  .mock-kicker {
    margin: 0;
    color: var(--muted);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Hero */
  .mock-hero {
    position: relative;
    overflow: hidden;
    min-height: calc(100svh - 6.4rem);
    display: flex;
    flex-direction: column;
  }

  .mock-hero__grid {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
    width: min(92rem, calc(100% - 3rem));
    max-width: 92rem;
    margin-inline: auto;
    padding-block: clamp(4.5rem, 8vh, 7rem) clamp(3rem, 5vh, 4rem);
  }

  .mock-hero__copy {
    position: relative;
    z-index: 3;
    max-width: min(44rem, 48%);
  }

  .mock-hero h1 {
    margin: 1.25rem 0 0;
    font-size: clamp(3.6rem, 4.8vw + 1.2rem, 6.1rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.065em;
  }

  .mock-hero__intro {
    max-width: 42rem;
    margin: 1.8rem 0 0;
    color: #263b47;
    font-size: clamp(1.05rem, 1.6vw, 1.35rem);
    font-weight: 400;
    line-height: 1.65;
    text-wrap: balance;
  }

  .mock-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.65rem;
    margin-top: 2.75rem;
  }

  .mock-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 3.65rem;
    padding: 0.95rem 1.45rem;
    border-radius: 0.35rem;
    font-size: 0.98rem;
    font-weight: 500;
    transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1), box-shadow 220ms ease;
  }

  .mock-button:hover {
    transform: translateY(-2px);
  }

  .mock-button:active {
    transform: translateY(1px) scale(0.985);
  }

  a.mock-button.mock-button--primary {
    color: var(--paper);
    background: var(--ink);
    box-shadow: 0 8px 22px rgba(31, 31, 28, 0.12);
  }

  a.mock-button.mock-button--light {
    color: #202220;
    background: #f4f0e8;
  }

  .mock-text-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--soft);
    font-size: 0.98rem;
    font-weight: 500;
  }

  .mock-text-link span {
    transition: transform 180ms ease;
  }

  .mock-text-link:hover {
    color: var(--ink);
  }

  .mock-text-link:hover span {
    transform: translate(2px, -1px);
  }

  .mock-text-link--on-dark {
    color: color-mix(in srgb, #f4f0e8 72%, transparent);
  }

  .mock-text-link--on-dark:hover {
    color: #f4f0e8;
  }

  .mock-refinement {
    position: absolute;
    left: auto;
    right: -1.5%;
    top: 53%;
    width: min(54%, 48rem);
    height: auto;
    aspect-ratio: 1;
    transform: translateY(-50%);
    margin: 0;
    z-index: 1;
    pointer-events: none;
    overflow: visible;
  }

  .mock-refinement img {
    position: static;
    width: 100%;
    max-width: 100%;
    height: 100%;
    display: block;
    margin: 0;
    object-fit: contain;
    object-position: center;
    mix-blend-mode: darken;
    opacity: 0.98;
    -webkit-mask-image: radial-gradient(circle, #000 68%, rgba(0, 0, 0, 0.72) 83%, transparent 100%);
    mask-image: radial-gradient(circle, #000 68%, rgba(0, 0, 0, 0.72) 83%, transparent 100%);
  }

  .mock-hero__foot {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.1rem;
    color: var(--muted);
    border-top: 1px solid var(--line);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* Proof strip */
  .mock-proof {
    border-top: 1px solid var(--line);
    background: var(--raised);
  }

  .mock-proof__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .mock-proof article {
    padding: clamp(2rem, 4vw, 3rem) clamp(1.25rem, 3vw, 2.5rem);
    border-right: 1px solid var(--line);
  }

  .mock-proof article:last-child {
    border-right: none;
  }

  .mock-proof h2 {
    margin: 0.85rem 0 0.7rem;
    font-size: clamp(1.55rem, 2.4vw, 2.1rem);
    font-weight: 500;
    letter-spacing: -0.04em;
  }

  .mock-proof p:last-child {
    margin: 0;
    max-width: 28rem;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.65;
  }

  /* Shared section chrome */
  .mock-section {
    padding-block: clamp(5.5rem, 10vw, 9rem);
    border-top: 1px solid var(--line);
  }

  .mock-section-head {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(16rem, 0.75fr);
    gap: clamp(2rem, 7vw, 8rem);
    align-items: end;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .mock-section-head h2,
  .mock-about__copy h2,
  .mock-skills h2,
  .mock-process__intro h2,
  .mock-contact h2 {
    margin: 0.85rem 0 0;
    font-size: clamp(2.2rem, 4.2vw, 4.2rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .mock-section-head > p,
  .mock-about__copy > p:not(.mock-kicker),
  .mock-skills header > p:not(.mock-kicker),
  .mock-process__intro > p:last-child,
  .mock-contact__copy > p {
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
  }

  /* About */
  .mock-about {
    background: var(--raised);
  }

  .mock-about__layout {
    display: grid;
    grid-template-columns: minmax(16rem, 0.95fr) minmax(22rem, 1.05fr);
    gap: clamp(1.5rem, 5vw, 4.5rem);
    align-items: start;
  }

  .mock-about__photo {
    margin: -0.5rem 0 0;
    max-width: 31rem;
    width: 100%;
    justify-self: start;
  }

  .mock-about__cutout {
    position: relative;
    display: grid;
    place-items: start center;
  }

  .mock-about__cutout::before {
    content: '';
    position: absolute;
    left: 18%;
    right: 18%;
    bottom: 4%;
    height: 14%;
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(40, 36, 30, 0.14), transparent 72%);
    filter: blur(8px);
    z-index: 0;
    pointer-events: none;
  }

  .mock-about__photo img {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 31rem;
    height: auto;
    display: block;
    object-fit: contain;
    /* Soft contact shadow only — blends without muddy bottom blur */
    filter: drop-shadow(0 16px 24px rgba(40, 36, 30, 0.1));
  }

  .mock-about__photo figcaption {
    margin-top: 0.75rem;
    text-align: left;
    color: var(--muted);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .mock-about__copy {
    padding-top: 0.35rem;
  }

  .mock-about__copy h2 {
    max-width: 14ch;
    margin-bottom: 1.5rem;
  }

  .mock-about__copy > p + p {
    margin-top: 1rem;
  }

  .mock-about__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem 1.5rem;
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .mock-about__meta a {
    color: var(--ink);
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
  }

  .mock-about__meta a span {
    display: inline-block;
    transition: transform 180ms ease;
  }

  .mock-about__meta a:hover span {
    transform: translateX(3px);
  }

  .mock-section-action {
    display: flex;
    justify-content: flex-end;
    margin-top: 2.25rem;
  }

  /* Systems — editorial feature + offset pair */
  .mock-systems__head {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .mock-systems__head-row {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(14rem, 0.65fr);
    gap: clamp(1.5rem, 5vw, 5rem);
    align-items: end;
    margin-top: 0.9rem;
  }

  .mock-systems__head-row h2 {
    margin: 0;
    font-size: clamp(2.2rem, 4.2vw, 4.2rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .mock-systems__head-row > p {
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
  }

  .mock-feature {
    margin-bottom: clamp(3.5rem, 7vw, 6rem);
  }

  .mock-feature > a {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(16rem, 0.75fr);
    gap: clamp(1.75rem, 4vw, 3.5rem);
    align-items: stretch;
  }

  .mock-feature__visual {
    position: relative;
    overflow: hidden;
    min-height: clamp(22rem, 42vw, 34rem);
    background: var(--deep);
    border-radius: 0.5rem;
  }

  .mock-feature__visual img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
    filter: saturate(0.96) contrast(1.02);
    transition: transform 700ms cubic-bezier(0.22, 1, 0.36, 1), filter 300ms ease;
  }

  .mock-feature:hover .mock-feature__visual img {
    transform: scale(1.03);
    filter: saturate(0.98) contrast(1);
  }

  .mock-feature__copy {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: 0.35rem;
  }

  .mock-feature__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    color: var(--muted);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .mock-feature__copy h3 {
    margin: 1.1rem 0 0;
    font-size: clamp(2rem, 3.4vw, 3.4rem);
    font-weight: 400;
    letter-spacing: -0.05em;
    line-height: 1.02;
  }

  .mock-feature__copy > p {
    max-width: 28rem;
    margin: 1.1rem 0 0;
    color: var(--muted);
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.65;
  }

  .mock-feature__copy ul,
  .mock-pair__copy ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.95rem;
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
    color: var(--muted);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.58rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .mock-feature__view,
  .mock-pair__view {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 1.6rem;
    font-size: 0.82rem;
    font-weight: 500;
  }

