---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import FeaturedPortfolioSection from '../components/FeaturedPortfolioSection.astro';
import HelpSignalGrid from '../components/HelpSignalGrid.astro';
import WhoPainList from '../components/WhoPainList.astro';
import {
  homeHelpCta,
  homeHelpIntro,
  homeHelpLabel,
  homeHelpTitle,
  homeWhoIntro,
  homeWhoTitle,
  site,
} from '../config/site';
import { getFeaturedProjects } from '../utils/content';

const featured = await getFeaturedProjects();
const homeContactStatus =
  'Available: selected AI workflow projects and implementation support.';
---

<Layout>
  <Hero />

  <section id="help" class="section-viewport section-flow home-help-section">
    <div class="container-main w-full">
      <div class="flex flex-col gap-8 md:gap-10 lg:gap-12 home-help-stack">
        <div class="section-label-row">
          <span class="section-label section-label--large">{homeHelpLabel}</span>
          <div class="section-label-rule"></div>
        </div>

        <div class="home-help-shell">
          <div class="help-who-block">
            <h2 class="help-who-block__title">{homeWhoTitle}</h2>
            <p class="help-who-block__intro section-subtitle-strong">{homeWhoIntro}</p>
            <WhoPainList />
          </div>

          <div class="home-signal-section">
            <div class="help-offerings-head">
              <h2 class="help-offerings-head__title">{homeHelpTitle}</h2>
              <p class="help-offerings-head__intro section-subtitle-strong">{homeHelpIntro}</p>
            </div>

            <HelpSignalGrid />
          </div>

          <div class="home-help-shell__actionbar" aria-label="Workflow audit action">
            <a href={homeHelpCta.href} class="home-help-shell__cta hero-cta-link">
              {homeHelpCta.label}
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FeaturedPortfolioSection projects={featured} />

  <section id="contact" class="section-padding-home section-flow home-contact-closing">
    <div class="container-main">
      <div class="section-label-row home-contact-closing__label">
        <span class="section-label section-label--large">CONTACT</span>
        <div class="section-label-rule"></div>
      </div>

      <article class="home-contact-panel" aria-labelledby="home-contact-title">
        <div class="home-contact-panel__copy">
          <h2 id="home-contact-title" class="home-contact-panel__title">
            Interested in working together?
          </h2>
          <p class="home-contact-panel__status">
            <span class="home-contact-panel__status-dot" aria-hidden="true"></span>
            <span>{homeContactStatus}</span>
          </p>
        </div>

        <div class="home-contact-panel__actionbar" aria-label="Contact actions">
          <a href={`mailto:${site.email}`} class="home-contact-panel__cta hero-cta-link">
            Get in Touch
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </article>
    </div>
  </section>
</Layout>
