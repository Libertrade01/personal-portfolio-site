---
import Layout from '../components/Layout.astro';
import { site } from '../config/site';
import { getFeaturedProjects } from '../utils/content';

const featured = await getFeaturedProjects();
const priority = [
  'libertrade-journal-analytics',
  'ai-daily-pulse',
  'macro-signal-room',
  'sentinel-mental-game-agent',
];
const systems = priority
  .map((slug) => featured.find((project) => project.slug === slug))
  .filter((project) => Boolean(project));

const process = [
  {
    title: 'Observe',
    description:
      'Understand how the work really happens, including repeated friction, unofficial workarounds, missing context and unclear ownership.',
  },
  {
    title: 'Simplify',
    description:
      'Reduce the process to its essential inputs, decisions, actions, hand-offs and exceptions.',
  },
  {
    title: 'Build',
    description:
      'Ship the smallest complete system people can use in real work, not just a demonstration of the underlying AI.',
  },
  {
    title: 'Iterate',
    description:
      'Watch where it fails, learn from edge cases and strengthen the workflow with clearer rules, human review and better feedback.',
  },
];

const skills = [
  {
    group: 'Workflow design',
    items: [
      'Process and constraint mapping',
      'Information architecture',
      'Human-in-the-loop flows',
      'Edge cases and escalation paths',
    ],
  },
  {
    group: 'Applied AI',
    items: [
      'LLM-assisted workflows',
      'Structured outputs',
      'Retrieval and knowledge systems',
      'Tool use and orchestration',
    ],
  },
  {
    group: 'Product engineering',
    items: [
      'TypeScript, Next.js and Astro',
      'Supabase and data modelling',
      'APIs, webhooks and integrations',
      'Deployment and monitoring',
    ],
  },
];
---

<Layout>
  <div class="mock">
    <section class="mock-hero" aria-labelledby="mock-hero-title">
      <div class="mock-shell mock-hero__grid">
        <div class="mock-hero__copy" data-reveal data-reveal-hero>
          <p class="mock-kicker">Applied AI · Workflow automation · Product engineering</p>
          <h1 id="mock-hero-title">Practical AI<br />Systems for<br />Messy Manual<br />Workflows.</h1>
          <p class="mock-hero__intro">
            I map how work gets done, identify the real constraint, and build AI-enabled workflows, internal tools and automation around it.
          </p>
          <div class="mock-actions">
            <a class="mock-button mock-button--primary" href="#systems">See what I've built</a>
            <a class="mock-text-link" href="#process">How I work <span aria-hidden="true">↓</span></a>
          </div>
        </div>

        <figure class="mock-refinement" data-reveal data-reveal-hero data-reveal-hero-media>
          <img
            src="/images/neural-system-hero.png"
            alt="An intricate spherical network of connected nodes and paths"
            width="1254"
            height="1254"
            loading="eager"
            decoding="async"
          />
        </figure>
      </div>
    </section>

    <!-- SYSTEMS: LOOP as feature, supporting projects compact -->
    <section id="systems" class="mock-section mock-systems" aria-labelledby="systems-title">
      <div class="mock-shell">
        <header class="mock-systems__head" data-reveal>
          <p class="mock-kicker">Systems</p>
          <h2 id="systems-title">AI systems built around real workflows.</h2>
          <p class="mock-systems__lede">
            Ambiguous manual workflows turned into systems people can actually run.
          </p>
        </header>

        {systems[0] && (
          <article class="mock-feature" data-reveal data-reveal-media>
            <a href={`/projects/${systems[0].slug}`} aria-label={`Read the ${systems[0].data.title} case study`}>
              <div class="mock-feature__visual">
                {systems[0].data.coverImage ? (
                  <img
                    src={systems[0].data.coverImage}
                    alt={`${systems[0].data.title} interface`}
                    loading="lazy"
                    decoding="async"
                  />
                ) : null}
              </div>
              <div class="mock-feature__copy">
                <div class="mock-feature__meta">
                  <span>{systems[0].data.category}</span>
                  <span>{systems[0].data.status}</span>
                </div>
                <h3>{systems[0].data.title}</h3>
                <p>{systems[0].data.description}</p>
                {systems[0].data.systemLine && (
                  <p class="mock-feature__system-line">{systems[0].data.systemLine}</p>
                )}
                <ul aria-label={`${systems[0].data.title} technologies`}>
                  {systems[0].data.stack.slice(0, 4).map((item) => <li>{item}</li>)}
                </ul>
                <span class="mock-feature__view">
                  Read case study <span aria-hidden="true">↗</span>
                </span>
              </div>
            </a>
          </article>
        )}

        <div class="mock-pair" data-reveal-stagger>
          {systems.slice(1).map((project) => {
            if (!project) return null;
            const {
              title,
              description,
              coverImage,
              cardImage,
              coverFit,
              coverPosition,
              category,
              status,
            } = project.data;
            const thumb = cardImage ?? coverImage;
            return (
              <article class="mock-pair__item" data-reveal data-reveal-media>
                <a href={`/projects/${project.slug}`} aria-label={`Read the ${title} case study`}>
                  <div class={`mock-pair__visual${coverFit === 'contain' ? ' mock-pair__visual--contain' : ''}`}>
                    {thumb ? (
                      <img
                        src={thumb}
                        alt={`${title} interface`}
                        loading="lazy"
                        decoding="async"
                        style={`object-fit: ${coverFit ?? 'cover'}; object-position: ${coverPosition ?? 'center top'};`}
                      />
                    ) : (
                      <span>{title}</span>
                    )}
                  </div>
                  <div class="mock-pair__copy">
                    <div class="mock-pair__meta">
                      <span>{category}</span>
                      <span>{status}</span>
                    </div>
                    <h3>{title}</h3>
                    <p>{description}</p>
                    <span class="mock-pair__view">
                      Case study <span aria-hidden="true">↗</span>
                    </span>
                  </div>
                </a>
              </article>
            );
          })}
        </div>

        <div class="mock-section-action" data-reveal>
          <a class="mock-text-link" href="/projects">View all systems <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    <!-- ABOUT: compact trust layer for hiring managers -->
    <section id="about" class="mock-section mock-about" aria-labelledby="about-title">
      <div class="mock-shell mock-about__layout">
        <figure class="mock-about__photo" data-reveal data-reveal-media>
          <div class="mock-about__frame">
            <img
              src={`${site.headshot}?v=2`}
              alt={`${site.name} portrait`}
              width="819"
              height="1024"
              loading="lazy"
              decoding="async"
            />
          </div>
        </figure>

        <div class="mock-about__copy" data-reveal data-reveal-delay="1">
          <p class="mock-kicker">About</p>
          <h2 id="about-title">I work where operations, product and engineering meet.</h2>
          <p>
            I’m most useful when the problem is still ambiguous: the process is spread across tools, important context lives in people’s heads, and nobody has written a clean specification.
          </p>
          <p>
            I study how the work actually happens, reduce it to the decisions, information and hand-offs that matter, and build a system around it. My work combines product thinking, applied AI and full-stack implementation.
          </p>
          <p>
            I care less about whether something looks agentic and more about whether it helps someone complete real work reliably.
          </p>
          <div class="mock-about__meta">
            <a href="/about">Full about page <span aria-hidden="true">→</span></a>
          </div>
        </div>
      </div>
    </section>

    <!-- SKILLS: made prominent for AI hiring managers -->
    <section id="skills" class="mock-section mock-skills" aria-labelledby="skills-title">
      <div class="mock-shell mock-skills__layout">
        <header data-reveal>
          <p class="mock-kicker">Capabilities</p>
          <h2 id="skills-title">I build the system around the model.</h2>
          <p>
            The useful part of applied AI is rarely the prompt alone. It is the workflow, data, interface, integration, guardrails and feedback loop that make it dependable.
          </p>
        </header>
        <div class="mock-skills__groups" data-reveal-stagger>
          {skills.map((skill) => (
            <div class="mock-skill-group" data-reveal>
              <p class="mock-kicker">{skill.group}</p>
              <ul>
                {skill.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section id="process" class="mock-section mock-process" aria-labelledby="process-title">
      <div class="mock-shell mock-process__layout">
        <header class="mock-process__intro" data-reveal>
          <p class="mock-kicker">How I work</p>
          <h2 id="process-title">Refinement is the work.</h2>
          <p>
            I rarely start with a clean specification. I start with scattered information, repeated friction and a problem that has not been properly framed yet.
          </p>
        </header>
        <ol class="mock-process__steps" data-reveal-stagger>
          {process.map((step, index) => (
            <li data-reveal>
              <span>0{index + 1}</span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- CONTACT: job-seeking framing -->
    <section id="contact" class="mock-contact" aria-labelledby="contact-title">
      <div class="mock-shell mock-contact__inner">
        <div data-reveal>
          <p class="mock-kicker">Work with me</p>
          <h2 id="contact-title">Looking for an applied AI builder who can work from ambiguity to production?</h2>
        </div>
        <div class="mock-contact__copy" data-reveal data-reveal-delay="1">
          <p>
            I map real workflows, build the tools and integrations around them, and refine them through real use. I’m open to applied AI engineering roles where I can do that work from inside the team.
          </p>
          <div class="mock-contact__actions">
            <a class="mock-button mock-button--light" href={`mailto:${site.email}`}>
              Email me <span aria-hidden="true">↗</span>
            </a>
            <a class="mock-text-link mock-text-link--on-dark" href={site.github} target="_blank" rel="noopener noreferrer">
              GitHub <span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const reveals = Array.from(document.querySelectorAll('[data-reveal]'));

    const show = (el) => el.classList.add('is-in');

    if (reduceMotion || !('IntersectionObserver' in window)) {
      reveals.forEach(show);
    } else {
      document.querySelectorAll('[data-reveal-hero]').forEach((el) => {
        window.setTimeout(() => show(el), 80);
      });

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            show(entry.target);
            observer.unobserve(entry.target);
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
      );

      reveals.forEach((el) => {
        if (el.hasAttribute('data-reveal-hero')) return;
        observer.observe(el);
      });
    }
  </script>
</Layout>

<style>
  .mock {
    --paper: #f4f0e8;
    --raised: #faf7f1;
    --deep: #e9e2d7;
    --ink: #1d1f1e;
    --soft: #454744;
    --muted: #77756f;
    --line: rgba(48, 47, 43, 0.14);
    --line-strong: rgba(48, 47, 43, 0.24);
    --signal: #3d5a4c;
    --grain: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    color: var(--ink);
    background: var(--paper);
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
  }

  .mock a {
    text-decoration: none;
  }

  .mock a:not(.mock-button) {
    color: inherit;
  }

  .mock-shell {
    width: min(92rem, calc(100% - 3rem));
    margin-inline: auto;
  }

  .mock-kicker {
    margin: 0;
    color: var(--muted);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Hero */
  .mock-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: calc(100svh - 6.4rem);
    display: flex;
    flex-direction: column;
    background: var(--paper);
  }

  .mock-hero::before,
  .mock-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .mock-hero::before {
    z-index: 0;
    background:
      radial-gradient(ellipse 38% 52% at 74% 40%, rgba(190, 128, 73, 0.22), transparent 68%),
      radial-gradient(ellipse 34% 46% at 15% 73%, rgba(50, 73, 77, 0.13), transparent 70%),
      radial-gradient(ellipse 29% 36% at 34% 24%, rgba(255, 255, 255, 0.72), transparent 68%),
      radial-gradient(ellipse 30% 42% at 91% 84%, rgba(118, 95, 72, 0.12), transparent 72%),
      linear-gradient(118deg, rgba(255, 255, 255, 0.4), transparent 46%);
  }

  .mock-hero::after {
    z-index: 2;
    opacity: 1;
    background-image:
      repeating-linear-gradient(7deg, rgba(75, 62, 48, 0.038) 0, rgba(75, 62, 48, 0.038) 1px, transparent 1px, transparent 4px),
      repeating-linear-gradient(97deg, rgba(255, 255, 255, 0.1) 0, rgba(255, 255, 255, 0.1) 1px, transparent 1px, transparent 9px);
    mix-blend-mode: multiply;
  }

  .mock-hero__grid {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
    width: min(92rem, calc(100% - 3rem));
    max-width: 92rem;
    margin-inline: auto;
    padding-block: clamp(4.5rem, 8vh, 7rem) clamp(3rem, 5vh, 4rem);
  }

  .mock-hero__copy {
    position: relative;
    z-index: 3;
    max-width: min(44rem, 48%);
  }

  .mock-hero h1 {
    margin: 1.25rem 0 0;
    font-size: clamp(3.6rem, 4.8vw + 1.2rem, 6.1rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.065em;
  }

  .mock-hero__intro {
    max-width: 42rem;
    margin: 1.8rem 0 0;
    color: #263b47;
    font-size: clamp(1.05rem, 1.6vw, 1.35rem);
    font-weight: 400;
    line-height: 1.65;
    text-wrap: balance;
  }

  .mock-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.65rem;
    margin-top: 2.75rem;
  }

  .mock-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 3.65rem;
    padding: 0.95rem 1.45rem;
    border-radius: 0.35rem;
    font-size: 0.98rem;
    font-weight: 500;
    transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1), box-shadow 220ms ease;
  }

  .mock-button:hover {
    transform: translateY(-2px);
  }

  .mock-button:active {
    transform: translateY(1px) scale(0.985);
  }

  a.mock-button.mock-button--primary {
    color: var(--paper);
    background: var(--ink);
    box-shadow: 0 8px 22px rgba(31, 31, 28, 0.12);
  }

  a.mock-button.mock-button--light {
    color: #202220;
    background: #f4f0e8;
  }

  .mock-text-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--soft);
    font-size: 0.98rem;
    font-weight: 500;
  }

  .mock-text-link span {
    transition: transform 180ms ease;
  }

  .mock-text-link:hover {
    color: var(--ink);
  }

  .mock-text-link:hover span {
    transform: translate(2px, -1px);
  }

  .mock-text-link--on-dark {
    color: color-mix(in srgb, #f4f0e8 72%, transparent);
  }

  .mock-text-link--on-dark:hover {
    color: #f4f0e8;
  }

  .mock-refinement {
    position: absolute;
    left: auto;
    right: -1.5%;
    top: 53%;
    width: min(54%, 48rem);
    height: auto;
    aspect-ratio: 1;
    transform: translateY(-50%);
    margin: 0;
    z-index: 1;
    pointer-events: none;
    overflow: visible;
  }

  .mock-refinement img {
    position: static;
    width: 100%;
    max-width: 100%;
    height: 100%;
    display: block;
    margin: 0;
    object-fit: contain;
    object-position: center;
    mix-blend-mode: darken;
    opacity: 0.98;
    -webkit-mask-image: radial-gradient(circle, #000 68%, rgba(0, 0, 0, 0.72) 83%, transparent 100%);
    mask-image: radial-gradient(circle, #000 68%, rgba(0, 0, 0, 0.72) 83%, transparent 100%);
  }

  .mock-hero__foot {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.1rem;
    color: var(--muted);
    border-top: 1px solid var(--line);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* Shared section chrome */
  .mock-section {
    padding-block: clamp(5.5rem, 10vw, 9rem);
    border-top: 1px solid var(--line);
  }

  .mock-section-head {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(16rem, 0.75fr);
    gap: clamp(2rem, 7vw, 8rem);
    align-items: end;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .mock-section-head h2,
  .mock-about__copy h2,
  .mock-skills h2,
  .mock-process__intro h2,
  .mock-contact h2 {
    margin: 0.85rem 0 0;
    font-size: clamp(2.2rem, 4.2vw, 4.2rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .mock-section-head > p,
  .mock-about__copy > p:not(.mock-kicker),
  .mock-skills header > p:not(.mock-kicker),
  .mock-process__intro > p:last-child,
  .mock-contact__copy > p {
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
  }

  /* About */
  .mock-about {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    /* Soft warm paper mid-tone — closer to site palette, not brown */
    background:
      radial-gradient(ellipse 60% 50% at 90% 8%, rgba(48, 47, 43, 0.04) 0%, transparent 65%),
      linear-gradient(165deg, #f3eee5 0%, #ebe5da 55%, #e5dfd3 100%);
  }

  .mock-about::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.07;
    background-image: var(--grain);
    background-size: 140px 140px;
    mix-blend-mode: multiply;
  }

  .mock-about > * {
    position: relative;
    z-index: 1;
  }

  .mock-about__layout {
    display: grid;
    grid-template-columns: minmax(16rem, 0.95fr) minmax(22rem, 1.05fr);
    gap: clamp(1.5rem, 5vw, 4.5rem);
    align-items: start;
  }

  .mock-about__photo {
    margin: 0;
    max-width: 22rem;
    width: 100%;
    justify-self: start;
  }

  .mock-about__frame {
    overflow: hidden;
    border-radius: 0.5rem;
    aspect-ratio: 4 / 5;
    background: var(--deep);
  }

  .mock-about__photo img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center 28%;
  }

  .mock-about__photo figcaption {
    margin-top: 0.75rem;
    text-align: left;
    color: var(--muted);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .mock-about__copy {
    padding-top: 0.35rem;
  }

  .mock-about__copy h2 {
    max-width: 18ch;
    margin-bottom: 1.5rem;
  }

  .mock-about__copy > p + p {
    margin-top: 1rem;
  }

  .mock-about__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem 1.5rem;
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .mock-about__meta a {
    color: var(--ink);
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
  }

  .mock-about__meta a span {
    display: inline-block;
    transition: transform 180ms ease;
  }

  .mock-about__meta a:hover span {
    transform: translateX(3px);
  }

  .mock-section-action {
    display: flex;
    justify-content: flex-end;
    margin-top: 2.25rem;
  }

  /* Systems — LOOP feature + compact supporting projects */
  .mock-systems {
    background: linear-gradient(180deg, #f7f4ee 0%, #f2eee6 100%);
  }

  .mock-systems__head {
    margin-bottom: clamp(3.75rem, 7.5vw, 6rem);
  }

  .mock-systems__head h2 {
    max-width: 16ch;
    margin: 0.75rem 0 0;
    font-size: clamp(2.2rem, 4.2vw, 4.2rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .mock-systems__lede {
    max-width: 34rem;
    margin: 0.85rem 0 0;
    color: var(--muted);
    font-size: 1.02rem;
    font-weight: 300;
    line-height: 1.6;
  }

  .mock-feature {
    margin-bottom: clamp(3.25rem, 6vw, 5rem);
  }

  .mock-feature > a {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(16rem, 0.75fr);
    gap: clamp(1.75rem, 4vw, 3.5rem);
    align-items: stretch;
  }

  .mock-feature__visual {
    position: relative;
    overflow: hidden;
    min-height: clamp(22rem, 42vw, 34rem);
    background: var(--deep);
    border-radius: 0;
    box-shadow: inset 0 0 0 1px rgba(48, 47, 43, 0.08);
  }

  .mock-feature__visual img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
