---
import Layout from '../components/Layout.astro';
---

<Layout title="Page not found">
  <section class="section-padding text-center">
    <div class="container-main">
      <h1 class="font-serif text-6xl text-amber-accent/30">404</h1>
      <p class="mt-4 text-muted">This page doesn't exist.</p>
      <a href="/" class="mt-8 inline-block text-amber-accent hover:underline">← Home</a>
    </div>
  </section>
</Layout>
