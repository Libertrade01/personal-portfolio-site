---
import { getCollection, render } from 'astro:content';
import Layout from '../../components/Layout.astro';
import CaseStudyHero from '../../components/case-study/CaseStudyHero.astro';
import OutcomeList from '../../components/OutcomeList.astro';
import RelatedProjects from '../../components/RelatedProjects.astro';
import { getPublishedProjects } from '../../utils/content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects
    .filter((p) => !p.data.draft)
    .map((project) => ({
      params: { slug: project.slug },
      props: { project },
    }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const allProjects = await getPublishedProjects();
const { title, description, outcomes } = project.data;
const caseStudySlugs = [
  'libertrade-journal-analytics',
  'sentinel-mental-game-agent',
  'macro-signal-room',
  'ai-daily-pulse',
  'book-inmobiliaria',
  'trading-knowledge-wiki',
] as const;
const isCaseStudy = caseStudySlugs.includes(project.slug as (typeof caseStudySlugs)[number]);
---

<Layout title={`${title} — Michael Low`} description={description} ogImage={project.data.coverImage}>
  <main class="project-case-study">
    <CaseStudyHero project={project} />
    <article class="project-case-study__article">
      <div class="project-case-study__body">
        {!isCaseStudy && outcomes.length > 0 && <OutcomeList outcomes={outcomes} />}
        <div class="project-case-study__content">
          <Content />
        </div>
      </div>
      <RelatedProjects projects={allProjects} currentSlug={project.slug} />
    </article>
  </main>
</Layout>

<style>
  .project-case-study {
    background: var(--ml-paper);
    color: var(--ml-ink);
  }

  .project-case-study__article {
    padding-block: clamp(3.5rem, 7vw, 7rem);
  }

  .project-case-study__body {
    width: var(--ml-shell);
    margin-inline: auto;
  }

  .project-case-study__content {
    color: var(--ml-ink-soft);
  }

  .project-case-study__content :global(> h2),
  .project-case-study__content :global(> h3),
  .project-case-study__content :global(> p),
  .project-case-study__content :global(> ul),
  .project-case-study__content :global(> ol) {
    width: min(100%, 46rem);
    margin-inline: auto;
  }

  .project-case-study__content :global(> h2) {
    margin-top: clamp(4.5rem, 8vw, 8rem);
    margin-bottom: 1.25rem;
    color: var(--ml-ink);
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4vw, 3.7rem);
    font-weight: 400;
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .project-case-study__content :global(> h2:first-child) {
    margin-top: 0;
  }

  .project-case-study__content :global(> h3) {
    margin-top: 2.5rem;
    margin-bottom: 0.65rem;
    color: var(--ml-ink);
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 500;
  }

  .project-case-study__content :global(> p),
  .project-case-study__content :global(> li) {
    font-size: clamp(0.98rem, 1.2vw, 1.08rem);
    font-weight: 300;
    line-height: 1.78;
  }

  .project-case-study__content :global(> p + p) {
    margin-top: 1rem;
  }

  .project-case-study__content :global(> ul),
  .project-case-study__content :global(> ol) {
    margin-top: 1.25rem;
    padding-left: 1.25rem;
  }

  .project-case-study__content :global(> ul li),
  .project-case-study__content :global(> ol li) {
    margin-top: 0.55rem;
    line-height: 1.65;
  }

  .project-case-study__content :global(a) {
    color: var(--ml-clay);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .project-case-study__content :global(strong) {
    color: var(--ml-ink);
    font-weight: 500;
  }
</style>
