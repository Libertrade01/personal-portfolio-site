---
import Layout from '../components/Layout.astro';
import SystemLayoutA from '../components/lab/SystemLayoutA.astro';
import SystemLayoutB from '../components/lab/SystemLayoutB.astro';
import SystemLayoutC from '../components/lab/SystemLayoutC.astro';
import SystemLayoutD from '../components/lab/SystemLayoutD.astro';
import SystemLayoutE from '../components/lab/SystemLayoutE.astro';
import { libertradeSystemPhases } from '../components/lab/system-phases';

const caseStudyHref = '/projects/libertrade-journal-analytics';

const options = [
  {
    id: 'a',
    name: 'Option A — Timeline (tightened)',
    desc: 'Vertical spine with amber dots — same pattern as the live case study, with tighter spacing and single-line phase copy.',
    Component: SystemLayoutA,
  },
  {
    id: 'b',
    name: 'Option B — Four-column strip',
    desc: 'Four equal cards in a row on desktop (2×2 on tablet) with connecting gradient line and step numbers.',
    Component: SystemLayoutB,
  },
  {
    id: 'c',
    name: 'Option C — 2×2 grid',
    desc: 'Balanced quad grid: numbered badge + title + body in each card-surface tile.',
    Component: SystemLayoutC,
  },
  {
    id: 'd',
    name: 'Option D — Pipeline bar',
    desc: 'Single fused bar: four segments divided by borders, mono phase labels, gradient progress strip below.',
    Component: SystemLayoutD,
  },
  {
    id: 'e',
    name: 'Option E — Chapter blocks (left border)',
    desc: 'Stacked chapters with left amber rule, mono “Chapter N” label, no cards — editorial flow.',
    Component: SystemLayoutE,
  },
] as const;
---

<Layout
  title="System layout lab — Michael Low"
  description="Compare five System section layouts for the Trading Review Operating System case study."
>
  <header class="border-b border-border py-12">
    <div class="container-main">
      <p class="section-label">Preview board</p>
      <h1 class="mt-4 font-serif text-4xl text-off-white md:text-5xl">
        System section — layout options
      </h1>
      <p class="mt-4 max-w-2xl text-muted">
        Five ways to present the same four-phase Libertrade workflow (Capture → Diagnose → Synthesize →
        Act). Scroll to compare — nothing here changes the live case study until you pick one.
      </p>
      <div class="mt-6 flex flex-wrap gap-4">
        <a href="/" class="link-arrow">← Home</a>
        <a
          href={caseStudyHref}
          class="font-mono text-xs uppercase tracking-wider text-muted hover:text-amber-accent"
        >
          Libertrade case study →
        </a>
        <a
          href="/ui-lab"
          class="font-mono text-xs uppercase tracking-wider text-muted hover:text-amber-accent"
        >
          UI lab →
        </a>
      </div>
    </div>
  </header>

  {
    options.map((option, index) => (
      <section
        id={option.id}
        class:list={[
          'section-padding border-t border-border',
          index === 0 && 'border-t-0',
        ]}
      >
        <div class="container-main max-w-4xl">
          <p class="font-mono text-[10px] uppercase tracking-widest text-amber-accent">{option.name}</p>
          <p class="mt-2 text-sm text-muted">{option.desc}</p>

          <div class="mt-10 rounded-2xl border border-border bg-charcoal/40 p-6 md:p-8">
            <p class="section-label">System</p>
            <h2 class="mt-4 font-serif text-2xl text-off-white">How the workflow runs</h2>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted">
              Context only — this intro is not part of the layout pick.
            </p>
            <option.Component phases={libertradeSystemPhases} />
          </div>
        </div>
      </section>
    ))
  }

  <section class="border-t border-border py-12">
    <div class="container-main max-w-4xl">
      <p class="text-sm text-muted">
        Ready to apply? Tell which option (A–E) to wire into
        <a href={caseStudyHref} class="text-amber-accent hover:underline">
          Trading Review Operating System
        </a>.
      </p>
    </div>
  </section>
</Layout>
