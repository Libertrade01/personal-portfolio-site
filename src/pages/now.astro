---
import { getEntry, render } from 'astro:content';
import Layout from '../components/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { formatDate } from '../utils/content';

const entry = await getEntry('now', 'index');
if (!entry) {
  return Astro.redirect('/404');
}
const { Content } = await render(entry);
const { title, updated } = entry.data;
---

<Layout title={`Now — ${title}`} description="What Michael Low is building and focusing on right now.">
  <PageHeader title="Now" subtitle="What I'm focused on — updated periodically." />
  <article class="section-padding">
    <div class="container-main max-w-3xl">
      <p class="text-sm text-muted">Last updated: {formatDate(updated)}</p>
      <div class="prose-content mt-8 space-y-6 text-muted [&_h2]:mb-4 [&_h2]:font-serif [&_h2]:text-2xl [&_h2]:text-off-white [&_li]:ml-4 [&_li]:list-disc [&_p]:leading-relaxed">
        <Content />
      </div>
    </div>
  </article>
</Layout>
